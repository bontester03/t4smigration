@model WebApit4s.Models.HealthScoreViewModel

@{
    ViewData["Title"] = "Questionnaire";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["ActivePage"] = "Questionnaire";
}

<style>
    .questionnaire-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        padding: 2rem;
        color: white;
        margin-bottom: 2rem;
        box-shadow: 0 8px 32px rgba(102, 126, 234, 0.3);
        position: relative;
        overflow: hidden;
    }
    .questionnaire-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }
    .questionnaire-card {
        border: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 15px;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
    }
    .questionnaire-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    .nav-tabs-modern {
        border: none;
        background: white;
        padding: 0.5rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .nav-tabs-modern .nav-link {
        border: none;
        border-radius: 8px;
        padding: 0.75rem 1.5rem;
        color: #6b7280;
        font-weight: 500;
        transition: all 0.3s;
        margin: 0 0.25rem;
    }
    .nav-tabs-modern .nav-link:hover {
        background: #f3f4f6;
        color: #667eea;
    }
    .nav-tabs-modern .nav-link.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }
    .question-group {
        background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
        border-left: 4px solid #667eea;
        border-radius: 10px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        transition: all 0.3s;
    }
    .question-group:hover {
        transform: translateX(5px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.2);
    }
    .question-group label {
        font-weight: 600;
        color: #1f2937;
        font-size: 1.05rem;
        margin-bottom: 0.5rem;
    }
    .question-group p {
        color: #6b7280;
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }
    .form-select {
        border-radius: 10px;
        border: 2px solid #e5e7eb;
        padding: 0.75rem 1rem;
        transition: all 0.3s;
    }
    .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    .submit-btn {
        border-radius: 10px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        transition: all 0.3s;
    }
    .submit-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }
    .table-modern {
        border-radius: 12px;
        overflow: hidden;
    }
    .table-modern thead {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }
    .table-modern thead th {
        border: none;
        padding: 1rem 0.75rem;
        font-weight: 600;
        font-size: 0.85rem;
    }
    .table-modern tbody td {
        padding: 0.875rem 0.75rem;
        vertical-align: middle;
        border-color: #e5e7eb;
        font-size: 0.875rem;
    }
    .table-modern tbody tr:hover {
        background-color: #f9fafb;
    }
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
    }
    .empty-state i {
        font-size: 3rem;
        color: #d1d5db;
        margin-bottom: 1rem;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <!-- Hero Section -->
    <div class="questionnaire-hero">
        <div class="row align-items-center position-relative">
            <div class="col-md-8">
                <h1 class="h2 fw-bold mb-2">
                    <i data-feather="clipboard" class="me-2"></i>
                    Health Questionnaire
                </h1>
                <p class="mb-0 opacity-90">Track your wellness journey through our comprehensive health assessment</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a asp-controller="Dashboard" asp-action="LandingPage" class="btn btn-light">
                    <i data-feather="arrow-left" class="me-2"></i>Back to Dashboard
                </a>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs-modern mb-4">
        <li class="nav-item">
            <a class="nav-link" asp-action="Index" asp-controller="Dashboard">
                <i data-feather="user" style="width: 16px; height: 16px;" class="me-1"></i>Profile
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Goal" asp-controller="Dashboard">
                <i data-feather="target" style="width: 16px; height: 16px;" class="me-1"></i>Tracking Goal
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link active" asp-action="Questionnaire" asp-controller="Dashboard">
                <i data-feather="clipboard" style="width: 16px; height: 16px;" class="me-1"></i>Questionnaire
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Measurement" asp-controller="Dashboard">
                <i data-feather="activity" style="width: 16px; height: 16px;" class="me-1"></i>Measurement
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Suggestions" asp-controller="Dashboard">
                <i data-feather="video" style="width: 16px; height: 16px;" class="me-1"></i>Videos
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Notifications" asp-controller="Dashboard">
                <i data-feather="bell" style="width: 16px; height: 16px;" class="me-1"></i>Notifications
            </a>
        </li>
    </ul>

    <!-- New Questionnaire Card -->
    <div class="questionnaire-card mb-4">
        <div class="card-header" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 1rem;">
            <h5 class="mb-0">
                <i data-feather="edit-3" class="me-2" style="width: 20px; height: 20px;"></i>
                New Questionnaire
            </h5>
        </div>

        <div class="card-body p-4">
            <form asp-action="CreateQuestionnaire" asp-controller="Dashboard" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                @* Physical Activity *@
                <div class="question-group">
                    <label>
                        <i data-feather="activity" style="width: 18px; height: 18px;" class="me-2"></i>
                        Physical Activity
                    </label>
                    <p>In the last 7 days, how many minutes has your child spent doing moderate or high intensity physical activity outside of school?</p>
                    <select asp-for="NewScore.PhysicalActivityScore" class="form-select">
                        <option value="-1">Select here</option>
                        <option value="0">Less than 60 mins</option>
                        <option value="1">60-120 mins</option>
                        <option value="2">180-240 mins</option>
                        <option value="3">300-360 mins</option>
                        <option value="4">420+ mins</option>
                    </select>
                    <span asp-validation-for="NewScore.PhysicalActivityScore" class="text-danger small"></span>
                </div>

                @* Breakfast *@
                <div class="question-group">
                    <label>
                        <i data-feather="coffee" style="width: 18px; height: 18px;" class="me-2"></i>
                        Breakfast
                    </label>
                    <p>How many days a week does your child have breakfast?</p>
                    <select asp-for="NewScore.BreakfastScore" class="form-select">
                        <option value="-1">Select here</option>
                        <option value="0">0 days</option>
                        <option value="1">1-2 days</option>
                        <option value="2">3-4 days</option>
                        <option value="3">5-6 days</option>
                        <option value="4">7 days</option>
                    </select>
                    <span asp-validation-for="NewScore.BreakfastScore" class="text-danger small"></span>
                </div>

                @* Fruit & Veg *@
                <div class="question-group">
                    <label>
                        <i data-feather="sun" style="width: 18px; height: 18px;" class="me-2"></i>
                        Fruit and Vegetable Intake
                    </label>
                    <p>How many portions of fruit/veg does your child eat per day?</p>
                    <select asp-for="NewScore.FruitVegScore" class="form-select">
                        <option value="-1">Select here</option>
                        <option value="0">0 portions</option>
                        <option value="1">1-2 portions</option>
                        <option value="2">3 portions</option>
                        <option value="3">4 portions</option>
                        <option value="4">5+ portions</option>
                    </select>
                    <span asp-validation-for="NewScore.FruitVegScore" class="text-danger small"></span>
                </div>

                @* Sweet Snacks *@
                <div class="question-group">
                    <label>
                        <i data-feather="alert-circle" style="width: 18px; height: 18px;" class="me-2"></i>
                        Sweet Snacks
                    </label>
                    <p>How often does your child eat sweet or savoury snack foods?</p>
                    <select asp-for="NewScore.SweetSnacksScore" class="form-select">
                        <option value="-1">Select here</option>
                        <option value="0">6+ times a week</option>
                        <option value="1">3-5 times a week</option>
                        <option value="2">1-2 times a week</option>
                        <option value="3">Less than 1 a week</option>
                        <option value="4">Never</option>
                    </select>
                    <span asp-validation-for="NewScore.SweetSnacksScore" class="text-danger small"></span>
                </div>

                @* Fatty Foods *@
                <div class="question-group">
                    <label>
                        <i data-feather="alert-triangle" style="width: 18px; height: 18px;" class="me-2"></i>
                        Fatty Foods
                    </label>
                    <p>How often does your child eat fatty foods?</p>
                    <select asp-for="NewScore.FattyFoodsScore" class="form-select">
                        <option value="-1">Select here</option>
                        <option value="0">6+ times a week</option>
                        <option value="1">3-5 times a week</option>
                        <option value="2">1-2 times a week</option>
                        <option value="3">Less than 1 a week</option>
                        <option value="4">Never</option>
                    </select>
                    <span asp-validation-for="NewScore.FattyFoodsScore" class="text-danger small"></span>
                </div>

                @* Date Recorded *@
                <div class="question-group">
                    <label>
                        <i data-feather="calendar" style="width: 18px; height: 18px;" class="me-2"></i>
                        Date Recorded
                    </label>
                    <input asp-for="NewScore.DateRecorded" class="form-control" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="NewScore.DateRecorded" class="text-danger small"></span>
                </div>

                <div class="text-center">
                    <button type="submit" class="btn btn-primary submit-btn">
                        <i data-feather="check-circle" class="me-2" style="width: 18px; height: 18px;"></i>
                        Submit Questionnaire
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Table Card -->
    <div class="questionnaire-card mb-5">
        <div class="card-header" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; padding: 1rem;">
            <h5 class="mb-0">
                <i data-feather="bar-chart-2" class="me-2" style="width: 20px; height: 20px;"></i>
                Questionnaire Results
            </h5>
        </div>
        <div class="card-body p-4">
            @if (Model.SubmittedScores == null || !Model.SubmittedScores.Any())
            {
                <div class="empty-state">
                    <i data-feather="clipboard" style="width: 64px; height: 64px;"></i>
                    <h5 class="mb-2">No Results Yet</h5>
                    <p class="text-muted mb-0">Complete your first questionnaire above to see your results here</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-modern table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Physical Activity</th>
                                <th>Breakfast</th>
                                <th>Fruit/Veg</th>
                                <th>Sweet Snacks</th>
                                <th>Fatty Foods</th>
                                <th>Total Score</th>
                                <th>Rating</th>
                                <th>Date Recorded</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var score in Model.SubmittedScores)
                            {
                                <tr>
                                    <td>@GetPhysicalActivityOption(score.PhysicalActivityScore)</td>
                                    <td>@GetBreakfastOption(score.BreakfastScore)</td>
                                    <td>@GetFruitVegOption(score.FruitVegScore)</td>
                                    <td>@GetSweetSnacksOption(score.SweetSnacksScore)</td>
                                    <td>@GetFattyFoodsOption(score.FattyFoodsScore)</td>
                                    <td><strong>@score.TotalScore</strong></td>
                                    <td>@Html.Raw(GetStarRating(score.TotalScore))</td>
                                    <td>@score.DateRecorded.ToString("MMM d, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof feather !== 'undefined') {
                feather.replace();
            }
        });
    </script>
}

@functions {
    private string GetPhysicalActivityOption(int score) => score switch
    {
        0 => "Less than 60 mins",
        1 => "60-120 mins",
        2 => "180-240 mins",
        3 => "300-360 mins",
        4 => "420+ mins",
        _ => "Unknown"
    };

    private string GetBreakfastOption(int score) => score switch
    {
        0 => "0 days",
        1 => "1-2 days",
        2 => "3-4 days",
        3 => "5-6 days",
        4 => "7 days",
        _ => "Unknown"
    };

    private string GetFruitVegOption(int score) => score switch
    {
        0 => "0 portions",
        1 => "1-2 portions",
        2 => "3 portions",
        3 => "4 portions",
        4 => "5+ portions",
        _ => "Unknown"
    };

    private string GetSweetSnacksOption(int score) => score switch
    {
        0 => "6+ times",
        1 => "3-5 times",
        2 => "1-2 times",
        3 => "Less than 1 a week",
        4 => "Never",
        _ => "Unknown"
    };

    private string GetFattyFoodsOption(int score) => score switch
    {
        0 => "6+ times",
        1 => "3-5 times",
        2 => "1-2 times",
        3 => "Less than 1 a week",
        4 => "Never",
        _ => "Unknown"
    };

    private string GetStarRating(int? score)
    {
        if (!score.HasValue) return "<span class='text-muted'>No Score</span>";
        int stars = score.Value switch
        {
            <= 5 => 1,
            <= 10 => 2,
            <= 15 => 3,
            <= 20 => 4,
            _ => 5
        };
        return $"<span style='color: #fbbf24;'>{new string('★', stars)}</span><span style='color: #e5e7eb;'>{new string('☆', 5 - stars)}</span>";
    }
}
@if (TempData["PopupMessage"] != null)
{
    <div class="modal fade" id="popupModal" tabindex="-1" aria-labelledby="popupLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="popupLabel">
                        <i class="fas fa-exclamation-triangle me-2"></i> Submission Blocked
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @TempData["PopupMessage"]
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var myModal = new bootstrap.Modal(document.getElementById('popupModal'));
            myModal.show();
        });
    </script>
}
