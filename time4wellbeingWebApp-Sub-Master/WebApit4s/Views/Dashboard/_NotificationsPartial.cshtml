@model WebApit4s.Models.UserDashboardViewModel

@if (Model == null || Model.Notifications == null || !Model.Notifications.Any())
{
    <p class="text-center p-2 text-muted">No new notifications</p>
}
else
{
    <ul class="list-group list-group-flush">
        @foreach (var notification in Model.Notifications)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <div class="dropdown-notifications-item-icon bg-warning me-2">
                        <i class="fa-solid fa-bell text-white"></i>
                    </div>
                    <span>@notification.Message</span>
                </div>
                <small class="text-muted">@notification.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
            </li>
        }
    </ul>
}
