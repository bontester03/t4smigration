@model List<WebApit4s.ViewModels.VideoSuggestionItemVM>
@using System.ComponentModel.DataAnnotations
@using System.Reflection
@{
    ViewData["Title"] = "Video Suggestions";
    ViewData["ActivePage"] = "Suggestions";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";

    string CatName(WebApit4s.Models.VideoCategory c)
    {
        var mem = typeof(WebApit4s.Models.VideoCategory).GetMember(c.ToString()).FirstOrDefault();
        var attr = mem?.GetCustomAttribute<DisplayAttribute>();
        return attr?.GetName() ?? c.ToString();
    }

    string CatBadge(WebApit4s.Models.VideoCategory c) => c switch
    {
        WebApit4s.Models.VideoCategory.PhysicalActivity => "bg-success",
        WebApit4s.Models.VideoCategory.Breakfast => "bg-warning text-dark",
        WebApit4s.Models.VideoCategory.FruitVeg => "bg-info text-dark",
        WebApit4s.Models.VideoCategory.SweetSnacks => "bg-primary",
        WebApit4s.Models.VideoCategory.FattyFoods => "bg-danger",
        _ => "bg-secondary"
    };
}

<style>
    .suggestions-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        padding: 2rem;
        color: white;
        margin-bottom: 2rem;
        box-shadow: 0 8px 32px rgba(102, 126, 234, 0.3);
        position: relative;
        overflow: hidden;
    }
    .suggestions-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }
    .suggestions-card {
        border: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 15px;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
    }
    .suggestions-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    .nav-tabs-modern {
        border: none;
        background: white;
        padding: 0.5rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .nav-tabs-modern .nav-link {
        border: none;
        border-radius: 8px;
        padding: 0.75rem 1.5rem;
        color: #6b7280;
        font-weight: 500;
        transition: all 0.3s;
        margin: 0 0.25rem;
    }
    .nav-tabs-modern .nav-link:hover {
        background: #f3f4f6;
        color: #667eea;
    }
    .nav-tabs-modern .nav-link.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }
    .video-card {
        border: none;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        border-radius: 15px;
        transition: all 0.3s;
        overflow: hidden;
        height: 100%;
    }
    .video-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(102, 126, 234, 0.2);
    }
    .video-thumbnail {
        position: relative;
        overflow: hidden;
        border-radius: 10px;
        transition: transform 0.3s;
    }
    .video-thumbnail:hover {
        transform: scale(1.05);
    }
    .video-thumbnail::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.3) 100%);
        opacity: 0;
        transition: opacity 0.3s;
    }
    .video-card:hover .video-thumbnail::after {
        opacity: 1;
    }
    .play-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60px;
        height: 60px;
        background: rgba(102, 126, 234, 0.9);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s;
        z-index: 2;
    }
    .video-card:hover .play-overlay {
        opacity: 1;
    }
    .watch-btn {
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        transition: all 0.3s;
    }
    .watch-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }
    .info-banner {
        background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
        border-left: 4px solid #667eea;
        border-radius: 10px;
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
    }
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }
    .empty-state i {
        font-size: 4rem;
        color: #d1d5db;
        margin-bottom: 1.5rem;
    }
</style>


<div class="container-fluid px-4 mt-4">
    <!-- Hero Section -->
    <div class="suggestions-hero">
        <div class="row align-items-center position-relative">
            <div class="col-md-8">
                <h1 class="h2 fw-bold mb-2">
                    <i data-feather="video" class="me-2"></i>
                    Video Suggestions
                </h1>
                <p class="mb-0 opacity-90">Personalized video recommendations to help improve your wellness journey</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a asp-controller="Dashboard" asp-action="LandingPage" class="btn btn-light">
                    <i data-feather="arrow-left" class="me-2"></i>Back to Dashboard
                </a>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs-modern mb-4">
        <li class="nav-item">
            <a class="nav-link" asp-action="Index" asp-controller="Dashboard">
                <i data-feather="user" style="width: 16px; height: 16px;" class="me-1"></i>Profile
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Goal" asp-controller="Dashboard">
                <i data-feather="target" style="width: 16px; height: 16px;" class="me-1"></i>Tracking Goal
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Questionnaire" asp-controller="Dashboard">
                <i data-feather="clipboard" style="width: 16px; height: 16px;" class="me-1"></i>Questionnaire
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Measurement" asp-controller="Dashboard">
                <i data-feather="activity" style="width: 16px; height: 16px;" class="me-1"></i>Measurement
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link active" asp-action="Suggestions" asp-controller="Dashboard">
                <i data-feather="video" style="width: 16px; height: 16px;" class="me-1"></i>Videos
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Notifications" asp-controller="Dashboard">
                <i data-feather="bell" style="width: 16px; height: 16px;" class="me-1"></i>Notifications
            </a>
        </li>
    </ul>

    <!-- Info Banner -->
    @if (!string.IsNullOrWhiteSpace(ViewBag.LowestActivities as string))
    {
        <div class="info-banner">
            <div class="d-flex align-items-center">
                <i data-feather="info" class="me-3" style="width: 24px; height: 24px; color: #667eea;"></i>
                <div>
                    <strong>Personalized for You:</strong> Based on your lowest scoring activities: <strong class="text-primary">@ViewBag.LowestActivities</strong>
                </div>
            </div>
        </div>
    }

    <!-- Suggestions Card -->
    <div class="suggestions-card mb-5">
        <div class="card-header" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 1rem;">
            <h5 class="mb-0">
                <i data-feather="film" class="me-2" style="width: 20px; height: 20px;"></i>
                Recommended Videos
            </h5>
        </div>

        <div class="card-body p-4">
            @if (Model != null && Model.Any())
            {
                <div class="row g-4">
                    @foreach (var v in Model)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="video-card">
                                <div class="position-relative p-3">
                                    <a asp-controller="VideoReward" asp-action="Watch" asp-route-id="@v.Id" class="text-decoration-none">
                                        <div class="video-thumbnail ratio ratio-16x9 mb-3">
                                            @if (!string.IsNullOrWhiteSpace(v.ThumbnailUrl))
                                            {
                                                <img src="@v.ThumbnailUrl" alt="@v.Title thumbnail" class="w-100 h-100"
                                                     style="object-fit:cover;" />
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center justify-content-center bg-light">
                                                    <i data-feather="video" style="width: 48px; height: 48px; color: #d1d5db;"></i>
                                                </div>
                                            }
                                            <div class="play-overlay">
                                                <i data-feather="play" style="width: 30px; height: 30px; color: white;"></i>
                                            </div>
                                        </div>
                                    </a>
                                    
                                    <div class="card-body text-center px-2 pb-3">
                                        <h5 class="card-title mb-3" style="font-size: 1rem; font-weight: 600;">@v.Title</h5>
                                        <div class="d-flex justify-content-center gap-2 mb-3 flex-wrap">
                                            <span class="badge @CatBadge(v.Category)" style="font-size: 0.8rem; padding: 0.4rem 0.8rem;">
                                                @CatName(v.Category)
                                            </span>
                                            <span class="badge" style="background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); font-size: 0.8rem; padding: 0.4rem 0.8rem;">
                                                <i data-feather="award" style="width: 14px; height: 14px;" class="me-1"></i>@v.CoinValue Coins
                                            </span>
                                        </div>
                                        <a asp-controller="VideoReward"
                                           asp-action="Watch"
                                           asp-route-id="@v.Id"
                                           class="btn btn-primary watch-btn w-100">
                                            <i data-feather="play-circle" class="me-2" style="width: 16px; height: 16px;"></i>
                                            Watch &amp; Earn
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i data-feather="video-off" style="width: 64px; height: 64px;"></i>
                    <h5 class="mb-2">No Video Suggestions Available</h5>
                    <p class="text-muted mb-3">Complete a health questionnaire to get personalized video recommendations</p>
                    <a asp-action="Questionnaire" asp-controller="Dashboard" class="btn btn-primary">
                        <i data-feather="clipboard" class="me-2" style="width: 16px; height: 16px;"></i>
                        Complete Questionnaire
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof feather !== 'undefined') {
                feather.replace();
            }
        });
    </script>
}
