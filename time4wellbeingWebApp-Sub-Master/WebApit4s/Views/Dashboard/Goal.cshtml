@model Dictionary<string, string>
@{
    ViewData["Title"] = "Tracking Goal";
    ViewData["ActivePage"] = "Goal";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var userScores = ViewBag.UserScores as List<WebApit4s.Models.HealthScore>;
}

<style>
    .goal-hero {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-radius: 15px;
        padding: 2rem;
        color: white;
        margin-bottom: 2rem;
        box-shadow: 0 8px 32px rgba(16, 185, 129, 0.3);
        position: relative;
        overflow: hidden;
    }
    .goal-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }
    .goal-card {
        border: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 15px;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
    }
    .goal-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    .nav-tabs-modern {
        border: none;
        background: white;
        padding: 0.5rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .nav-tabs-modern .nav-link {
        border: none;
        border-radius: 8px;
        padding: 0.75rem 1.5rem;
        color: #6b7280;
        font-weight: 500;
        transition: all 0.3s;
        margin: 0 0.25rem;
    }
    .nav-tabs-modern .nav-link:hover {
        background: #f3f4f6;
        color: #10b981;
    }
    .nav-tabs-modern .nav-link.active {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }
    .goal-item {
        background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
        border-left: 4px solid #10b981;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
        transition: all 0.3s;
    }
    .goal-item:hover {
        transform: translateX(5px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
    }
    .score-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.875rem;
    }
    .badge-excellent { background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; }
    .badge-good { background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; }
    .badge-fair { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; }
    .badge-poor { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; }
    
    .table-modern {
        border-radius: 12px;
        overflow: hidden;
    }
    .table-modern thead {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
    }
    .table-modern thead th {
        border: none;
        padding: 1rem;
        font-weight: 600;
        font-size: 0.85rem;
    }
    .table-modern tbody td {
        padding: 0.875rem;
        vertical-align: middle;
        border-color: #e5e7eb;
    }
    .table-modern tbody tr:hover {
        background-color: #f9fafb;
    }
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
    }
    .empty-state i {
        font-size: 3rem;
        color: #d1d5db;
        margin-bottom: 1rem;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <!-- Hero Section -->
    <div class="goal-hero">
        <div class="row align-items-center position-relative">
            <div class="col-md-8">
                <h1 class="h2 fw-bold mb-2">
                    <i data-feather="target" class="me-2"></i>
                    Tracking Your Goals
                </h1>
                <p class="mb-0 opacity-90">Monitor your progress and achieve your wellness targets</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a asp-controller="Dashboard" asp-action="LandingPage" class="btn btn-light">
                    <i data-feather="arrow-left" class="me-2"></i>Back to Dashboard
                </a>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs-modern mb-4">
        <li class="nav-item">
            <a class="nav-link" asp-action="Index" asp-controller="Dashboard">
                <i data-feather="user" style="width: 16px; height: 16px;" class="me-1"></i>Profile
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link active" asp-action="Goal" asp-controller="Dashboard">
                <i data-feather="target" style="width: 16px; height: 16px;" class="me-1"></i>Tracking Goal
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Questionnaire" asp-controller="Dashboard">
                <i data-feather="clipboard" style="width: 16px; height: 16px;" class="me-1"></i>Questionnaire
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Measurement" asp-controller="Dashboard">
                <i data-feather="activity" style="width: 16px; height: 16px;" class="me-1"></i>Measurement
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Suggestions" asp-controller="Dashboard">
                <i data-feather="video" style="width: 16px; height: 16px;" class="me-1"></i>Videos
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Notifications" asp-controller="Dashboard">
                <i data-feather="bell" style="width: 16px; height: 16px;" class="me-1"></i>Notifications
            </a>
        </li>
    </ul>

    <!-- Goals and History -->
    <div class="row g-4">
        <!-- Suggested Goals -->
        <div class="col-lg-6">
            <div class="goal-card">
                <div class="card-header" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; padding: 1rem;">
                    <h5 class="mb-0">
                        <i data-feather="check-circle" class="me-2" style="width: 20px; height: 20px;"></i>
                        Your Suggested Goals
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (Model == null)
                    {
                        <div class="empty-state">
                            <i data-feather="clipboard" style="width: 64px; height: 64px;"></i>
                            <h5 class="mb-2">No Health Scores Found</h5>
                            <p class="text-muted mb-3">Complete a questionnaire to get your personalized goals</p>
                            <a asp-action="Questionnaire" asp-controller="Dashboard" class="btn btn-success">
                                <i data-feather="edit" class="me-2" style="width: 16px; height: 16px;"></i>
                                Complete Questionnaire
                            </a>
                        </div>
                    }
                    else if (!Model.Any())
                    {
                        <div class="empty-state">
                            <i data-feather="award" style="width: 64px; height: 64px; color: #10b981;"></i>
                            <h5 class="mb-2 text-success">Excellent Work!</h5>
                            <p class="text-muted">You're meeting your goals in all areas. Keep up the great work!</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var goal in Model)
                        {
                            <div class="goal-item">
                                <div class="d-flex align-items-start">
                                    <div class="flex-shrink-0 me-3">
                                        <i data-feather="arrow-right-circle" style="width: 24px; height: 24px; color: #10b981;"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <strong class="d-block mb-1">@goal.Key</strong>
                                        <span class="text-muted">@goal.Value</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Historical Scores -->
        <div class="col-lg-6">
            <div class="goal-card">
                <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 1rem;">
                    <h5 class="mb-0">
                        <i data-feather="trending-up" class="me-2" style="width: 20px; height: 20px;"></i>
                        Historical Health Scores
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (userScores == null || userScores.Count == 0)
                    {
                        <div class="empty-state">
                            <i data-feather="bar-chart-2" style="width: 64px; height: 64px;"></i>
                            <h5 class="mb-2">No Historical Data</h5>
                            <p class="text-muted">Your health scores will appear here once you complete questionnaires</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-modern table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Physical</th>
                                        <th>Breakfast</th>
                                        <th>Fruit/Veg</th>
                                        <th>Snacks</th>
                                        <th>Fatty</th>
                                        <th>Total</th>
                                        <th>Rating</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var score in userScores)
                                    {
                                        <tr>
                                            <td><small>@GetPhysicalActivityOption(score.PhysicalActivityScore)</small></td>
                                            <td><small>@GetBreakfastOption(score.BreakfastScore)</small></td>
                                            <td><small>@GetFruitVegOption(score.FruitVegScore)</small></td>
                                            <td><small>@GetSweetSnacksOption(score.SweetSnacksScore)</small></td>
                                            <td><small>@GetFattyFoodsOption(score.FattyFoodsScore)</small></td>
                                            <td>
                                                <span class="score-badge @GetBadgeClass(score.TotalScore)">
                                                    @score.TotalScore
                                                </span>
                                            </td>
                                            <td>@Html.Raw(GetStarRating(score.TotalScore))</td>
                                            <td><small>@score.DateRecorded.ToString("MMM d, yyyy")</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof feather !== 'undefined') {
                feather.replace();
            }
        });
    </script>
}

@functions {
    private string GetPhysicalActivityOption(int score) => score switch
    {
        0 => "<60 mins",
        1 => "60-120 mins",
        2 => "180-240 mins",
        3 => "300-360 mins",
        4 => "420+ mins",
        _ => "Unknown"
    };

    private string GetBreakfastOption(int score) => score switch
    {
        0 => "0 days",
        1 => "1-2 days",
        2 => "3-4 days",
        3 => "5-6 days",
        4 => "7 days",
        _ => "Unknown"
    };

    private string GetFruitVegOption(int score) => score switch
    {
        0 => "0 portions",
        1 => "1-2 portions",
        2 => "3 portions",
        3 => "4 portions",
        4 => "5+ portions",
        _ => "Unknown"
    };

    private string GetSweetSnacksOption(int score) => score switch
    {
        0 => "6+ times",
        1 => "3-5 times",
        2 => "1-2 times",
        3 => "<1 time",
        4 => "Never",
        _ => "Unknown"
    };

    private string GetFattyFoodsOption(int score) => score switch
    {
        0 => "6+ times",
        1 => "3-5 times",
        2 => "1-2 times",
        3 => "<1 time",
        4 => "Never",
        _ => "Unknown"
    };

    private string GetBadgeClass(int? totalScore)
    {
        if (!totalScore.HasValue) return "";
        
        return totalScore.Value switch
        {
            >= 20 => "badge-excellent",
            >= 15 => "badge-good",
            >= 10 => "badge-fair",
            _ => "badge-poor"
        };
    }

    private string GetStarRating(int? totalScore)
    {
        if (!totalScore.HasValue) return "<span class='text-muted'>-</span>";

        int stars = totalScore.Value switch
        {
            <= 5 => 1,
            <= 10 => 2,
            <= 15 => 3,
            <= 20 => 4,
            _ => 5
        };

        string filledStars = new string('★', stars);
        string emptyStars = new string('☆', 5 - stars);

        return $"<span style='color: #fbbf24;'>{filledStars}</span><span style='color: #e5e7eb;'>{emptyStars}</span>";
    }
}
