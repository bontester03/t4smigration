<div class="container-xl px-4">
    <div class="row justify-content-center">
        @if (Model == null || !Model.Any())
        {
            <div class="col-md-8 mt-4">
                <div class="alert alert-warning text-center">You don’t have any children registered yet.</div>
                <div class="text-center">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">Add Child</a>
                </div>
            </div>
        }
        else
        {
            @foreach (var child in Model)
            {
                <div class="col-xl-4 col-lg-5 col-md-6 col-sm-10 mt-4">
                    <form asp-action="SetActiveChild" method="post" class="card text-center h-100">
                        <div class="card-body px-5 pt-5 d-flex flex-column">
                            <div>
                                <div class="h4 text-primary">@child.ChildName</div>
                                <p class="text-muted mb-3">DOB: @child.DateOfBirth.ToShortDateString()</p>
                            </div>
                            <div class="icons-org-create align-items-center mx-auto mt-auto mb-3">
                                <img src="@(string.IsNullOrWhiteSpace(child.AvatarUrl)
                                                 ? Url.Content("~/images/default-child-avatar.png")
                                                 : Url.Content(child.AvatarUrl))"
                             alt="@child.ChildName avatar"
                             class="rounded-circle child-avatar"
                             width="100" height="100" />

                            </div>

                        </div>
                        <div class="card-footer bg-transparent px-5 py-4">
                            <input type="hidden" name="childId" value="@child.Id" />
                            <button type="submit" class="btn btn-block btn-primary">Select</button>
                        </div>
                    </form>
                </div>
            }
        }
    </div>
</div>

