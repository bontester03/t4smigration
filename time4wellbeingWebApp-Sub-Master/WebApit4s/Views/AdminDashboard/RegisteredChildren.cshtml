@model X.PagedList.IPagedList<WebApit4s.Models.ChildViewModel>
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Registered Children";
    ViewData["ActivePage"] = "RegisteredChildren";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    
    // Calculate analytics
    var totalChildren = Model.TotalItemCount;
    var maleCount = Model.Count(c => c.Gender.Equals("Male", StringComparison.OrdinalIgnoreCase));
    var femaleCount = Model.Count(c => c.Gender.Equals("Female", StringComparison.OrdinalIgnoreCase));
    var thisMonth = Model.Count(c => c.RegistrationDate.Month == DateTime.Now.Month && c.RegistrationDate.Year == DateTime.Now.Year);
}

<style>
    .stat-card {
        border-left: 4px solid;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }
    .filter-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 10px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        color: white;
    }
    .filter-section .form-label {
        color: white;
        font-weight: 500;
        margin-bottom: 0.25rem;
    }
    .child-row {
        transition: all 0.2s;
    }
    .child-row:hover {
        background-color: rgba(0, 123, 255, 0.05);
        transform: scale(1.01);
    }
    .child-card {
        border-left: 3px solid #007bff;
        transition: all 0.3s;
    }
    .child-card:hover {
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        transform: translateX(5px);
    }
    .gender-badge-male {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .gender-badge-female {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }
</style>

<div class="container-fluid px-4 mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-1">
                <i class="fas fa-child text-info me-2"></i> Registered Children
            </h2>
            <p class="text-muted mb-0">View and manage all registered children in the system</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Dashboard
        </a>
    </div>
    <!-- Analytics Cards -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card border-0 shadow-sm h-100" style="border-left-color: #007bff !important;">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">Total Children</div>
                            <div class="h3 mb-0 fw-bold text-primary">@totalChildren</div>
                        </div>
                        <div class="text-primary" style="font-size: 2.5rem; opacity: 0.3;">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card stat-card border-0 shadow-sm h-100" style="border-left-color: #667eea !important;">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">Male</div>
                            <div class="h3 mb-0 fw-bold" style="color: #667eea;">@maleCount</div>
                            <small class="text-muted">@(totalChildren > 0 ? ((maleCount / (double)totalChildren) * 100).ToString("F1") : "0")%</small>
                        </div>
                        <div style="font-size: 2.5rem; opacity: 0.3; color: #667eea;">
                            <i class="fas fa-mars"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card stat-card border-0 shadow-sm h-100" style="border-left-color: #f5576c !important;">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">Female</div>
                            <div class="h3 mb-0 fw-bold" style="color: #f5576c;">@femaleCount</div>
                            <small class="text-muted">@(totalChildren > 0 ? ((femaleCount / (double)totalChildren) * 100).ToString("F1") : "0")%</small>
                        </div>
                        <div style="font-size: 2.5rem; opacity: 0.3; color: #f5576c;">
                            <i class="fas fa-venus"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card stat-card border-0 shadow-sm h-100" style="border-left-color: #28a745 !important;">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">This Month</div>
                            <div class="h3 mb-0 fw-bold text-success">@thisMonth</div>
                            <small class="text-muted">@DateTime.Now.ToString("MMM yyyy")</small>
                        </div>
                        <div class="text-success" style="font-size: 2.5rem; opacity: 0.3;">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section shadow-sm">
        <h5 class="mb-3"><i class="fas fa-filter me-2"></i>Filter Children</h5>
        <form asp-action="RegisteredChildren" method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label"><i class="fas fa-calendar-alt me-1"></i>Start Date</label>
                <input type="date" name="startDate" class="form-control bg-white" value="@ViewBag.StartDate" />
            </div>

            <div class="col-md-3">
                <label class="form-label"><i class="fas fa-calendar-alt me-1"></i>End Date</label>
                <input type="date" name="endDate" class="form-control bg-white" value="@ViewBag.EndDate" />
            </div>

            <div class="col-md-3">
                <label class="form-label"><i class="fas fa-tags me-1"></i>Referral Type</label>
                <select name="referralTypeId" class="form-select bg-white">
                    <option value="">All Referral Types</option>
                    @foreach (var referral in ViewBag.ReferralTypes as List<SelectListItem>)
                    {
                        var selected = referral.Value == ViewBag.SelectedReferralType ? "selected" : "";
                        <option value="@referral.Value" selected="@selected">@referral.Text</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">
                    <i class="fas fa-school me-1"></i>School Name
                    <i class="fas fa-info-circle ms-1" data-bs-toggle="tooltip" 
                       title="Filter by school name"></i>
                </label>
                <input type="text" name="schoolName" class="form-control bg-white" 
                       value="@ViewBag.SchoolName" placeholder="Enter school name" />
            </div>

            <div class="col-md-6">
                <label class="form-label">
                    <i class="fas fa-child me-1"></i>Child Name
                    <i class="fas fa-info-circle ms-1" data-bs-toggle="tooltip" 
                       title="Filter by child name"></i>
                </label>
                <input type="text" name="childName" class="form-control bg-white" 
                       value="@ViewBag.ChildName" placeholder="Enter child name" />
            </div>

            <div class="col-md-6 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-light flex-fill">
                    <i class="fas fa-search me-1"></i> Apply Filters
                </button>
                <a asp-action="RegisteredChildren" class="btn btn-outline-light flex-fill">
                    <i class="fas fa-redo me-1"></i> Clear All
                </a>
            </div>
        </form>
    </div>
    @if (Model != null && Model.Any())
    {
        <!-- Desktop Table View -->
        <div class="card shadow-sm border-0 mb-4 d-none d-md-block">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0 text-dark">
                    <i class="fas fa-list me-2"></i>Children Records
                    <span class="badge bg-primary ms-2">@Model.TotalItemCount</span>
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-3">Child Info</th>
                                <th>Date of Birth</th>
                                <th class="text-center">Gender</th>
                                <th>School</th>
                                <th>Referral Type</th>
                                <th class="text-center">Registration</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var child in Model)
                            {
                                var genderClass = child.Gender.Equals("Male", StringComparison.OrdinalIgnoreCase) ? "gender-badge-male" : "gender-badge-female";
                                var genderIcon = child.Gender.Equals("Male", StringComparison.OrdinalIgnoreCase) ? "fa-mars" : "fa-venus";

                                <tr class="child-row">
                                    <td class="px-3">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-info text-white me-2" 
                                                 style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                                @child.ChildName.Substring(0, 1).ToUpper()
                                            </div>
                                            <div>
                                                <div class="fw-bold">@child.ChildName</div>
                                                <small class="text-muted">
                                                    <i class="fas fa-envelope me-1"></i>@child.Email
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <small>
                                            <i class="far fa-calendar me-1"></i>
                                            @child.DateOfBirth.ToString("dd MMM yyyy")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @genderClass text-white">
                                            <i class="fas @genderIcon me-1"></i>@child.Gender
                                        </span>
                                    </td>
                                    <td>
                                        <small>
                                            <i class="fas fa-school me-1 text-muted"></i>@child.School
                                        </small>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@child.ReferralTypeName</span>
                                    </td>
                                    <td class="text-center">
                                        <small class="text-muted">
                                            <i class="far fa-clock me-1"></i>
                                            @child.RegistrationDate.ToString("dd MMM yyyy")
                                            <br />
                                            @child.RegistrationDate.ToString("HH:mm")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a class="btn btn-sm btn-outline-primary" 
                                               asp-action="ViewChildDetails" 
                                               asp-controller="AdminDashboard" 
                                               asp-route-childId="@child.ChildId"
                                               data-bs-toggle="tooltip" 
                                               title="View all details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-info" 
                                               asp-action="ChildDetails" 
                                               asp-controller="AdminDashboard" 
                                               asp-route-id="@child.ChildId"
                                               data-bs-toggle="tooltip" 
                                               title="Assign tasks">
                                                <i class="fas fa-tasks"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Mobile Card View -->
        <div class="d-md-none">
            @foreach (var child in Model)
            {
                var genderClass = child.Gender.Equals("Male", StringComparison.OrdinalIgnoreCase) ? "gender-badge-male" : "gender-badge-female";
                var genderIcon = child.Gender.Equals("Male", StringComparison.OrdinalIgnoreCase) ? "fa-mars" : "fa-venus";

                <div class="card child-card shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center">
                                <div class="avatar-circle bg-info text-white me-2" 
                                     style="width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem;">
                                    @child.ChildName.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <div class="fw-bold">@child.ChildName</div>
                                    <small class="text-muted">
                                        <i class="fas fa-envelope me-1"></i>@child.Email
                                    </small>
                                </div>
                            </div>
                            <span class="badge @genderClass text-white">
                                <i class="fas @genderIcon me-1"></i>@child.Gender
                            </span>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <small class="text-muted d-block">Date of Birth</small>
                                <small><i class="far fa-calendar me-1"></i>@child.DateOfBirth.ToString("dd MMM yyyy")</small>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">School</small>
                                <small><i class="fas fa-school me-1"></i>@child.School</small>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Referral Type</small>
                                <span class="badge bg-secondary">@child.ReferralTypeName</span>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Registered</small>
                                <small><i class="far fa-clock me-1"></i>@child.RegistrationDate.ToString("dd MMM yyyy")</small>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-primary flex-fill" 
                               asp-action="ViewChildDetails" 
                               asp-controller="AdminDashboard" 
                               asp-route-childId="@child.ChildId">
                                <i class="fas fa-eye me-1"></i> View All
                            </a>
                            <a class="btn btn-sm btn-outline-info flex-fill" 
                               asp-action="ChildDetails" 
                               asp-controller="AdminDashboard" 
                               asp-route-id="@child.ChildId">
                                <i class="fas fa-tasks me-1"></i> Tasks
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="d-flex justify-content-center mt-4">
            @Html.PagedListPager(
                Model, 
                page => Url.Action("RegisteredChildren", new {
                    page,
                    startDate = ViewBag.StartDate,
                    endDate = ViewBag.EndDate,
                    referralTypeId = ViewBag.SelectedReferralType,
                    childName = ViewBag.ChildName,
                    schoolName = ViewBag.SchoolName
                }),
                new PagedListRenderOptions
                {
                    UlElementClasses = new[] { "pagination" },
                    LiElementClasses = new[] { "page-item" },
                    PageClasses = new[] { "page-link" },
                    DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                    DisplayLinkToLastPage = PagedListDisplayMode.Always,
                    LinkToFirstPageFormat = "First",
                    LinkToLastPageFormat = "Last"
                }
            )
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="fas fa-child fa-4x text-muted mb-3"></i>
                <h5 class="text-muted">No registered children found</h5>
                <p class="text-muted mb-0">Try adjusting your filters or check back later.</p>
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Initialize tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.forEach(function (tooltipTriggerEl) {
            new bootstrap.Tooltip(tooltipTriggerEl);
        });
    });
</script>

