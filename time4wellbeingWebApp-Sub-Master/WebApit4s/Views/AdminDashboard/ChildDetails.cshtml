@model WebApit4s.ViewModels.AdminChildOverviewViewModel
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var child = Model.Child;
}

<div class="container-fluid px-2 px-md-4">
    <!-- Header / Back -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">
            <i class="fas fa-child me-2"></i> Child Overview
        </h4>
        <a asp-action="RegisteredChildren" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to Registered Children
        </a>
    </div>

    <!-- Child Info Card -->
    <div class="card mb-4 shadow-sm border-start border-3 border-success">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center">
            <div>
                <h5 class="mb-1">
                    <i class="fas fa-user text-primary me-2"></i>@child.ChildName
                </h5>
                <div class="text-muted">
                    <span class="me-3"><i class="fas fa-birthday-cake me-1 text-secondary"></i> Age: <strong>@child.Age</strong></span>
                    <span class="me-3"><i class="fas fa-coins me-1 text-warning"></i> Coins: <strong>@child.TotalPoints</strong></span>
                </div>
            </div>
            <div class="text-end">
                <div class="small text-muted">Parent</div>
                <div class="fw-semibold">
                    <i class="fas fa-envelope me-1"></i>@(child.User?.Email ?? "Unknown")
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs flex-wrap mb-3" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-active">Active Tasks</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-done">Completed / Expired</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-points">Point History</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-rewards">Parent Rewards</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-redemptions">Redemptions</button></li>
    </ul>

    <div class="tab-content">
        <!-- Active Tasks -->
        <div class="tab-pane fade show active" id="tab-active">
            <div class="card shadow-sm mb-4">
                <div class="card-body table-responsive">
                    @if (Model.ActiveTasks.Any())
                    {
                        <table class="table table-bordered table-striped table-hover align-middle">
                            <thead class="table-success">
                                <tr>
                                    <th>Task</th>
                                    <th>Description</th>
                                    <th>Points</th>
                                    <th>Assigned</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.ActiveTasks)
                                {
                                    <tr>
                                        <td>
                                            @t.GameTask?.Title
                                            @if (t.GameTask?.IsCommonTask == true)
                                            {
                                                <span class="badge bg-info ms-1">Common</span>
                                            }
                                        </td>
                                        <td class="text-truncate">@t.GameTask?.Description</td>
                                        <td><strong>@(t.GameTask?.Points ?? 0)</strong></td>
                                        <td>@t.AssignedDate.ToString("dd MMM yyyy")</td>
                                        <td><span class="badge bg-warning text-dark">Pending</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No active tasks.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Completed / Expired -->
        <div class="tab-pane fade" id="tab-done">
            <div class="card shadow-sm mb-4">
                <div class="card-body table-responsive">
                    @if (Model.CompletedOrExpiredTasks.Any())
                    {
                        <table class="table table-bordered table-striped table-hover align-middle">
                            <thead class="table-secondary">
                                <tr>
                                    <th>Task</th>
                                    <th>Description</th>
                                    <th>Points</th>
                                    <th>Assigned</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.CompletedOrExpiredTasks)
                                {
                                    <tr>
                                        <td>@t.GameTask?.Title</td>
                                        <td class="text-truncate">@t.GameTask?.Description</td>
                                        <td><strong>@(t.GameTask?.Points ?? 0)</strong></td>
                                        <td>@t.AssignedDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (t.IsCompleted)
                                            {
                                                <span class="badge bg-success">Completed</span>
                                            }
                                            else if (t.IsExpired)
                                            {
                                                <span class="badge bg-danger">Expired</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No completed or expired tasks yet.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Point History -->
        <div class="tab-pane fade" id="tab-points">
            <div class="card shadow-sm mb-4">
                <div class="card-body table-responsive">
                    @if (Model.PointHistory.Any())
                    {
                        <table class="table table-bordered table-striped table-hover align-middle">
                            <thead class="table-info">
                                <tr>
                                    <th>Change</th>
                                    <th>Balance</th>
                                    <th>Reason</th>
                                    <th>Notes</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in Model.PointHistory)
                                {
                                    <tr>
                                        <td class="@(h.Delta >= 0 ? "text-success fw-bold" : "text-danger fw-bold")">
                                            @((h.Delta >= 0 ? "+" : "") + h.Delta)
                                        </td>
                                        <td><strong>@h.BalanceAfter</strong></td>
                                        <td><span class="badge bg-info text-dark">@h.Reason</span></td>
                                        <td>@h.Notes</td>
                                        <td>@h.CreatedUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No point history for this child.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Parent Rewards (visible to this child) -->
        <div class="tab-pane fade" id="tab-rewards">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span>
                        <i class="fas fa-gift me-1"></i> Rewards
                    </span>
                    <span class="small">
                        @(Model?.ParentRewards?.Count ?? 0) item(s)
                    </span>
                </div>

                <div class="card-body">
                    @if (Model.ParentRewards == null || !Model.ParentRewards.Any())
                    {
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle me-1"></i> No rewards available for this child.
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var r in Model.ParentRewards)
                            {
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="card h-100 shadow-sm border-0">
                                        <div class="card-body">
                                            <!-- Title & Cost -->
                                            <div class="d-flex justify-content-between align-items-start">
                                                <h5 class="card-title mb-1">@r.Title</h5>
                                                <span class="badge bg-info">
                                                    <i class="fas fa-coins me-1"></i>@r.CoinCost
                                                </span>
                                            </div>

                                            <!-- Description -->
                                            @if (!string.IsNullOrWhiteSpace(r.Description))
                                            {
                                                <p class="card-text text-muted mb-2">@r.Description</p>
                                            }

                                            <!-- Badges -->
                                            <div class="mb-2">
                                                @if (r.IsCommon)
                                                {
                                                    <span class="badge bg-secondary me-1">
                                                        <i class="fas fa-users me-1"></i> Common
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-dark me-1">
                                                        <i class="fas fa-child me-1"></i> Child-specific
                                                    </span>
                                                }

                                                @if (r.RequiresParentApproval)
                                                {
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="fas fa-check-double me-1"></i> Requires approval
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-bolt me-1"></i> Instant
                                                    </span>
                                                }
                                            </div>

                                            <!-- Validity -->
                                            <div class="small text-muted">
                                                @{
                                                    var fromTxt = r.ValidFromUtc?.ToLocalTime().ToString("dd MMM yyyy");
                                                    var toTxt = r.ValidToUtc?.ToLocalTime().ToString("dd MMM yyyy");
                                                }

                                                @if (r.ValidFromUtc.HasValue || r.ValidToUtc.HasValue)
                                                {
                                                    <div>
                                                        <i class="far fa-calendar-alt me-1"></i>
                                                        @(fromTxt ?? "Any") – @(toTxt ?? "Any")
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div>
                                                        <i class="far fa-calendar-alt me-1"></i> Any time
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <!-- Footer -->
                                        <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                                            <span class="badge bg-secondary">Reward ID: @r.Id</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>


        <!-- Redemptions -->
        <div class="tab-pane fade" id="tab-redemptions">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span>
                        <i class="fas fa-receipt me-1"></i> Reward Redemptions
                    </span>
                    <span class="small">
                        @(Model?.Redemptions?.Count ?? 0) item(s)
                    </span>
                </div>

                <div class="card-body">
                    @if (Model.Redemptions == null || !Model.Redemptions.Any())
                    {
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle me-1"></i> No redemptions for this child yet.
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var r in Model.Redemptions)
                            {
                                var statusClass = r.Status switch
                                {
                                    ParentReward.ParentRewardRedemptionStatus.Requested => "warning",
                                    ParentReward.ParentRewardRedemptionStatus.Approved => "primary",
                                    ParentReward.ParentRewardRedemptionStatus.Redeemed => "success",
                                    ParentReward.ParentRewardRedemptionStatus.Rejected => "danger",
                                    _ => "secondary"
                                };

                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="card h-100 shadow-sm border-0">
                                        <div class="card-body">
                                            <!-- Title & Cost -->
                                            <div class="d-flex justify-content-between align-items-start">
                                                <h5 class="card-title mb-1">@r.ParentReward?.Title</h5>
                                                <span class="badge bg-info">
                                                    <i class="fas fa-coins me-1"></i>@r.CoinCostAtPurchase
                                                </span>
                                            </div>

                                            <!-- Status -->
                                            <div class="mb-2">
                                                <span class="badge bg-@statusClass">
                                                    <i class="fas fa-flag me-1"></i>@r.Status
                                                </span>
                                            </div>

                                            <!-- Timeline -->
                                            <div class="small text-muted">
                                                <div>
                                                    <i class="far fa-calendar-plus me-1"></i>
                                                    Requested: @r.RequestedUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                                </div>
                                                <div>
                                                    <i class="far fa-calendar-check me-1"></i>
                                                    Approved: @(r.ApprovedUtc?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")
                                                </div>
                                                <div>
                                                    <i class="fas fa-gift me-1"></i>
                                                    Redeemed: @(r.RedeemedUtc?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")
                                                </div>
                                            </div>

                                            <!-- Notes -->
                                            @if (!string.IsNullOrWhiteSpace(r.Notes))
                                            {
                                                <p class="card-text text-muted mt-2">
                                                    <i class="fas fa-sticky-note me-1"></i>@r.Notes
                                                </p>
                                            }
                                        </div>

                                        <!-- Footer -->
                                        <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                                            <span class="badge bg-secondary">Redemption ID: @r.Id</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>
