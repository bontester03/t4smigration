@model WebApit4s.Models.HealthScore

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_layoutMain.cshtml";
}


<div class="col-md-6 d-flex align-items-center py-5">
    <div class="container my-auto py-4 shadow-lg bg-white">
        <div class="row">
            <div class="col-11 col-lg-10 mx-auto">
                <h3 class="text-9 fw-600 text-center my-3">Health Score Submission</h3>
                <p class="text-muted text-center mb-4">Complete the form to log your child's health data.</p>

                <form asp-action="Create" method="post" class="w-full max-w-lg mx-auto">
                    <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3"></div>

                    <!-- Physical Activity -->
                    <div class="mb-4" id="card-1">
                        <h5 class="fw-bold text-success mb-2">Physical Activity</h5>
                        <label class="form-label">In the last 7 days, on average, how many minutes has your child spent doing moderate or higher intensity physical activity?</label>
                        <select asp-for="PhysicalActivityScore" class="form-control rounded-0">
                            <option value="">Select...</option>
                            <option value="0">Less than 60 mins</option>
                            <option value="1">60-120 mins</option>
                            <option value="2">180-240 mins</option>
                            <option value="3">300-360 mins</option>
                            <option value="4">420+ mins</option>
                        </select>
                        <span asp-validation-for="PhysicalActivityScore" class="text-danger"></span>
                    </div>

                    <!-- Breakfast -->
                    <div class="mb-4 d-none" id="card-2">
                        <h5 class="fw-bold text-success mb-2">Breakfast</h5>
                        <label class="form-label">How many days a week does your child have breakfast?</label>
                        <select asp-for="BreakfastScore" class="form-control rounded-0">
                            <option value="">Select...</option>
                            <option value="0">0</option>
                            <option value="1">1-2</option>
                            <option value="2">3-4</option>
                            <option value="3">5-6</option>
                            <option value="4">7</option>
                        </select>
                        <span asp-validation-for="BreakfastScore" class="text-danger"></span>
                    </div>

                    <!-- Fruit and Vegetable Intake -->
                    <div class="mb-4 d-none" id="card-3">
                        <h5 class="fw-bold text-success mb-2">Fruit and Vegetable Intake</h5>
                        <label class="form-label">How many portions of fruit/veg does your child eat per day?</label>
                        <select asp-for="FruitVegScore" class="form-control rounded-0">
                            <option value="">Select...</option>
                            <option value="0">0 portions</option>
                            <option value="1">1-2 portions</option>
                            <option value="2">3 portions</option>
                            <option value="3">4 portions</option>
                            <option value="4">5+ portions</option>
                        </select>
                        <span asp-validation-for="FruitVegScore" class="text-danger"></span>
                    </div>

                    <!-- Sweet Snacks -->
                    <div class="mb-4 d-none" id="card-4">
                        <h5 class="fw-bold text-success mb-2">Sweet Snacks</h5>
                        <label class="form-label">How often does your child eat/drink sweet or savory snacks?</label>
                        <select asp-for="SweetSnacksScore" class="form-control rounded-0">
                            <option value="">Select...</option>
                            <option value="0">6+ times a week</option>
                            <option value="1">3-5 times a week</option>
                            <option value="2">1-2 times a week</option>
                            <option value="3">Less than 1 a week</option>
                            <option value="4">Never</option>
                        </select>
                        <span asp-validation-for="SweetSnacksScore" class="text-danger"></span>
                    </div>

                    <!-- Fatty Foods -->
                    <div class="mb-4 d-none" id="card-5">
                        <h5 class="fw-bold text-success mb-2">Fatty Foods</h5>
                        <label class="form-label">How often does your child eat fatty foods?</label>
                        <select asp-for="FattyFoodsScore" class="form-control rounded-0">
                            <option value="">Select...</option>
                            <option value="0">6+ times a week</option>
                            <option value="1">3-5 times a week</option>
                            <option value="2">1-2 times a week</option>
                            <option value="3">Less than 1 a week</option>
                            <option value="4">Never</option>
                        </select>
                        <span asp-validation-for="FattyFoodsScore" class="text-danger"></span>
                    </div>

                    <!-- Date Recorded -->
                    <div class="mb-4 d-none" id="card-6">
                        <h5 class="fw-bold text-success mb-2">Date Recorded</h5>
                        <label class="form-label">Date Recorded</label>
                        <input asp-for="DateRecorded" type="date" class="form-control rounded-0" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="DateRecorded" class="text-danger"></span>
                    </div>

                    <!-- Submit Button -->
                    <div class="d-none" id="submit-btn">
                        <button type="submit" class="btn btn-success w-100 py-2 mt-2">Save and Continue</button>
                    </div>
                </form>
                <div class="d-flex align-items-center my-4">
                    <hr class="flex-grow-1">
                    <span class="mx-2 text-2 text-muted">Part-4</span>
                    <hr class="flex-grow-1">
                </div>

                <div id="success-message" class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center bg-white bg-opacity-75 z-index-1050">
                    <img src="~/images/success-graphic.png" alt="Profile Created!" class="w-25 mb-3 animate__animated animate__bounce" />
                    <h2 class="text-success fw-bold">Profile Created Successfully!</h2>
                    <p class="text-muted">Redirecting to Dashboard...</p>
                    <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.querySelector('form');
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            document.getElementById('success-message').classList.remove('d-none');
            setTimeout(function () {
                form.submit();
            }, 2000);
        });

        const cards = document.querySelectorAll('[id^="card-"]');
        cards.forEach((card, index) => {
            const select = card.querySelector('select');
            if (select) {
                select.addEventListener('change', () => {
                    if (select.value !== "" && index < cards.length - 1) {
                        card.classList.add('d-none');
                        cards[index + 1].classList.remove('d-none');
                    }
                    if (index === cards.length - 2) {
                        document.getElementById('submit-btn').classList.remove('d-none');
                    }
                });
            }
        });
    });
</script>
