@{
    ViewBag.Title = "Link Generated";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white d-flex align-items-center">
                    <i class="fa fa-link fa-lg me-2"></i>
                    <h5 class="mb-0">Guest Link Created</h5>
                </div>
                <div class="card-body text-center">
                    <p class="mb-3 text-muted">
                        Share this link with the guest to allow them to register directly.
                    </p>

                    <div class="input-group mb-3">
                        <input type="text"
                               id="generatedLinkInput"
                               value="@ViewBag.GeneratedLink"
                               readonly
                               class="form-control" />

                        <button type="button"
                                class="btn btn-outline-primary"
                                onclick="copyToClipboard('generatedLinkInput')">
                            <i class="fa fa-copy me-1"></i> Copy
                        </button>
                    </div>

                    <div class="d-flex justify-content-center gap-2">
                        <a class="btn btn-secondary" asp-action="Create">
                            <i class="fa fa-plus-circle me-1"></i> Generate Another
                        </a>
                        <a class="btn btn-outline-success" asp-action="Index">
                            <i class="fa fa-home me-1"></i> Back to Links
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div class="modal fade" id="copySuccessModal" tabindex="-1" aria-labelledby="copySuccessLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content text-center p-3">
            <div class="modal-body">
                <i class="fa fa-check-circle text-success fa-2x mb-2"></i>
                <p class="mb-0 fw-semibold">Link copied successfully!</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyToClipboard(inputId) {
            var copyText = document.getElementById(inputId);
            copyText.select();
            copyText.setSelectionRange(0, 99999); // For mobile
            navigator.clipboard.writeText(copyText.value).then(function () {
                var modal = new bootstrap.Modal(document.getElementById('copySuccessModal'));
                modal.show();

                // Auto-hide after 2 seconds
                setTimeout(function () {
                    modal.hide();
                }, 2000);
            });
        }
    </script>
}
