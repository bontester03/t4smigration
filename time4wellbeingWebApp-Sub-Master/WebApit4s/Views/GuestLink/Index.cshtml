@model GuestLinkListViewModel

@{
    ViewBag.Title = "All Guest Links";
    ViewData["ActivePage"] = "GuestLinks";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .guest-link-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        padding: 3rem 2rem;
        color: white;
        margin-bottom: 2rem;
        box-shadow: 0 8px 32px rgba(102, 126, 234, 0.3);
    }
    .guest-link-card {
        border: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 15px;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
    }
    .guest-link-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    .feature-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }
    .status-badge {
        font-size: 0.85rem;
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
    }
    .link-table thead th {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        font-weight: 600;
        padding: 1rem;
    }
    .link-table tbody tr {
        transition: background-color 0.2s;
    }
    .link-table tbody tr:hover {
        background-color: #f8f9fa;
    }
    .copy-btn {
        transition: all 0.3s;
    }
    .copy-btn:hover {
        transform: scale(1.05);
    }
    .filter-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        padding: 2rem;
        margin-bottom: 2rem;
    }
    .stats-card {
        background: white;
        border-radius: 10px;
        padding: 1.5rem;
        text-align: center;
        border: 2px solid #e9ecef;
        transition: all 0.3s;
    }
    .stats-card:hover {
        border-color: #667eea;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.2);
    }
</style>

<div class="container-fluid px-4 mt-4">
    <!-- Hero Section -->
    <div class="guest-link-hero">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="fw-bold mb-3">
                    <i data-feather="link" class="me-3"></i>Guest Registration Links
                </h1>
                <p class="lead mb-0">
                    Manage and monitor all guest registration links for schools and classes
                </p>
            </div>
            <div class="col-md-4 text-md-end">
                <a asp-action="Create" class="btn btn-light btn-lg">
                    <i data-feather="plus-circle" class="me-2"></i>Create New Link
                </a>
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i data-feather="alert-triangle" class="me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i data-feather="check-circle" class="me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Quick Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stats-card">
                <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    <i data-feather="link"></i>
                </div>
                <h3 class="fw-bold mb-1">@Model.GuestLinks.Count</h3>
                <p class="text-muted mb-0">Total Links</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card">
                <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #28a745 0%, #218838 100%); color: white;">
                    <i data-feather="check-circle"></i>
                </div>
                <h3 class="fw-bold mb-1">@Model.GuestLinks.Count(l => !l.IsDisabled && (!l.ExpiryDate.HasValue || l.ExpiryDate > DateTime.UtcNow))</h3>
                <p class="text-muted mb-0">Active Links</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card">
                <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); color: white;">
                    <i data-feather="users"></i>
                </div>
                <h3 class="fw-bold mb-1">@Model.GuestLinks.Sum(l => l.Uses)</h3>
                <p class="text-muted mb-0">Total Uses</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card">
                <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%); color: white;">
                    <i data-feather="clock"></i>
                </div>
                <h3 class="fw-bold mb-1">@Model.GuestLinks.Count(l => l.ExpiryDate.HasValue && l.ExpiryDate < DateTime.UtcNow)</h3>
                <p class="text-muted mb-0">Expired Links</p>
            </div>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section">
        <h5 class="fw-bold mb-3">
            <i data-feather="filter" class="me-2"></i>Filter Links
        </h5>
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label for="SchoolId" class="form-label fw-bold">School</label>
                <select asp-for="SchoolId" asp-items="Model.Schools" class="form-select form-select-lg">
                    <option value="">All Schools</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label fw-bold">From Date</label>
                <input type="date" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control form-control-lg" />
            </div>

            <div class="col-md-3">
                <label class="form-label fw-bold">To Date</label>
                <input type="date" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control form-control-lg" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i data-feather="search" class="me-2"></i>Filter
                </button>
            </div>
        </form>
    </div>

    <!-- Links Table -->
    @if (Model.GuestLinks.Any())
    {
        <!-- Desktop / Tablet table (md and up) -->
        <div class="d-none d-md-block">
            <div class="card guest-link-card mb-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table link-table mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>
                                        <i data-feather="home" class="me-1" style="width: 16px; height: 16px;"></i>
                                        School
                                    </th>
                                    <th>
                                        <i data-feather="book" class="me-1" style="width: 16px; height: 16px;"></i>
                                        Class
                                    </th>
                                    <th>
                                        <i data-feather="link" class="me-1" style="width: 16px; height: 16px;"></i>
                                        Registration Link
                                    </th>
                                    <th>
                                        <i data-feather="calendar" class="me-1" style="width: 16px; height: 16px;"></i>
                                        Expiry
                                    </th>
                                    <th>
                                        <i data-feather="users" class="me-1" style="width: 16px; height: 16px;"></i>
                                        Uses
                                    </th>
                                    <th>
                                        <i data-feather="activity" class="me-1" style="width: 16px; height: 16px;"></i>
                                        Status
                                    </th>
                                    <th>
                                        <i data-feather="settings" class="me-1" style="width: 16px; height: 16px;"></i>
                                        Action
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var link in Model.GuestLinks)
                                {
                                    var isExpired = link.ExpiryDate.HasValue && link.ExpiryDate.Value < DateTime.UtcNow;
                                    <tr>
                                        <td class="fw-semibold">@(link.School?.Name ?? "-")</td>
                                        <td>@(link.Class?.Name ?? "-")</td>
                                        <td>
                                            <div class="input-group input-group-sm">
                                                <input type="text"
                                                       id="link-@link.Id"
                                                       value="@($"{Context.Request.Scheme}://{Context.Request.Host}{Url.Content($"~/guest-registration/{link.UniqueCode}/step-1")}")"
                                                       readonly
                                                       class="form-control text-truncate"
                                                       style="max-width: 300px;" />
                                                <button type="button"
                                                        class="btn btn-outline-primary copy-btn"
                                                        onclick="copyToClipboard('link-@link.Id')"
                                                        title="Copy to clipboard">
                                                    <i data-feather="copy" style="width: 16px; height: 16px;"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-muted">
                                                @(link.ExpiryDate?.ToString("dd MMM yyyy") ?? "No Expiry")
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-info">
                                                @link.Uses / @(link.MaxUses?.ToString() ?? "∞")
                                            </span>
                                        </td>
                                        <td>
                                            @if (link.IsDisabled)
                                            {
                                                <span class="status-badge badge bg-danger">
                                                    <i data-feather="x-circle" style="width: 14px; height: 14px;"></i> Disabled
                                                </span>
                                            }
                                            else if (isExpired)
                                            {
                                                <span class="status-badge badge bg-warning text-dark">
                                                    <i data-feather="clock" style="width: 14px; height: 14px;"></i> Expired
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="status-badge badge bg-success">
                                                    <i data-feather="check-circle" style="width: 14px; height: 14px;"></i> Active
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <button type="button"
                                                    class="btn btn-sm btn-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteConfirmModal"
                                                    data-id="@link.Id"
                                                    title="Delete this link">
                                                <i data-feather="trash-2" style="width: 14px; height: 14px;"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mobile cards (shown on < md) -->
        <div class="d-md-none">
            @foreach (var link in Model.GuestLinks)
            {
                var isExpired = link.ExpiryDate.HasValue && link.ExpiryDate.Value < DateTime.UtcNow;
                <div class="card guest-link-card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h6 class="fw-bold mb-1">@(link.School?.Name ?? "-")</h6>
                                <p class="text-muted small mb-0">
                                    <i data-feather="book" style="width: 14px; height: 14px;"></i>
                                    @(link.Class?.Name ?? "-")
                                </p>
                            </div>
                            <div>
                                @if (link.IsDisabled)
                                {
                                    <span class="badge bg-danger">Disabled</span>
                                }
                                else if (isExpired)
                                {
                                    <span class="badge bg-warning text-dark">Expired</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </div>
                        </div>

                        <div class="mb-2 small">
                            <i data-feather="calendar" class="me-1" style="width: 14px; height: 14px;"></i>
                            <span class="text-muted">Expiry:</span> @(link.ExpiryDate?.ToString("dd MMM yyyy") ?? "No Expiry")
                        </div>
                        <div class="mb-3 small">
                            <i data-feather="users" class="me-1" style="width: 14px; height: 14px;"></i>
                            <span class="text-muted">Uses:</span> @link.Uses / @(link.MaxUses?.ToString() ?? "∞")
                        </div>

                        <label class="form-label small fw-bold text-muted">Registration Link</label>
                        <div class="input-group mb-3">
                            <input type="text"
                                   id="link-m-@link.Id"
                                   value="@($"{Context.Request.Scheme}://{Context.Request.Host}{Url.Content($"~/guest-registration/{link.UniqueCode}/step-1")}")"
                                   readonly
                                   class="form-control form-control-sm" />
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary"
                                    onclick="copyToClipboard('link-m-@link.Id')">
                                <i data-feather="copy" style="width: 14px; height: 14px;"></i>
                            </button>
                        </div>

                        <div class="d-grid">
                            <button type="button"
                                    class="btn btn-danger btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteConfirmModal"
                                    data-id="@link.Id">
                                <i data-feather="trash-2" class="me-1" style="width: 14px; height: 14px;"></i> Delete Link
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card guest-link-card">
            <div class="card-body text-center p-5">
                <div class="mb-3" style="font-size: 4rem; color: #dee2e6;">
                    <i data-feather="inbox"></i>
                </div>
                <h5 class="fw-bold mb-2">No Guest Links Found</h5>
                <p class="text-muted mb-4">
                    @if (Model.SchoolId.HasValue || Model.FromDate.HasValue || Model.ToDate.HasValue)
                    {
                        <text>No links match your filter criteria. Try adjusting your filters or create a new guest link.</text>
                    }
                    else
                    {
                        <text>You haven't created any guest registration links yet. Get started by creating your first link!</text>
                    }
                </p>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i data-feather="plus-circle" class="me-2"></i>Create Your First Guest Link
                </a>
            </div>
        </div>
    }

    <!-- Quick Actions Card -->
    <div class="row g-4 mt-3">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="mb-3" style="font-size: 3rem; color: #667eea;">
                        <i data-feather="home"></i>
                    </div>
                    <h5 class="fw-bold mb-2">School Pages</h5>
                    <p class="text-muted mb-3">
                        View all school-specific registration pages with organized class links
                    </p>
                    <a asp-action="SchoolLinksIndex" class="btn btn-outline-primary">
                        <i data-feather="arrow-right" class="me-1"></i>View School Pages
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center p-4">
                    <div class="mb-3" style="font-size: 3rem; color: #28a745;">
                        <i data-feather="plus-circle"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Create New Link</h5>
                    <p class="text-muted mb-3">
                        Generate a new guest registration link for a school and class
                    </p>
                    <a asp-action="Create" class="btn btn-outline-success">
                        <i data-feather="link" class="me-1"></i>Create Guest Link
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Copy success modal -->
<div class="modal fade" id="copySuccessModal" tabindex="-1" aria-labelledby="copySuccessLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-success">
            <div class="modal-header" style="background: linear-gradient(135deg, #28a745 0%, #218838 100%); color: white;">
                <h5 class="modal-title" id="copySuccessLabel">
                    <i data-feather="check-circle" class="me-2"></i>Link Copied Successfully!
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center">
                    <div class="mb-3" style="font-size: 3rem; color: #28a745;">
                        <i data-feather="clipboard"></i>
                    </div>
                    <p class="mb-0">
                        The registration link has been copied to your clipboard.
                        You can now share it with parents or guardians!
                    </p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" data-bs-dismiss="modal">
                    <i data-feather="thumbs-up" class="me-1"></i>Got it!
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header" style="background: linear-gradient(135deg, #dc3545 0%, #bd2130 100%); color: white;">
                <h5 class="modal-title" id="deleteConfirmLabel">
                    <i data-feather="alert-triangle" class="me-2"></i>Confirm Deletion
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center">
                    <div class="mb-3" style="font-size: 3rem; color: #dc3545;">
                        <i data-feather="trash-2"></i>
                    </div>
                    <h6 class="fw-bold mb-2">Are you sure you want to delete this link?</h6>
                    <p class="text-muted mb-0">
                        This action cannot be undone. The link will be permanently removed and will no longer be accessible.
                    </p>
                </div>
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post" class="d-inline">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i data-feather="x" class="me-1"></i>Cancel
                    </button>
                    <button type="submit" class="btn btn-danger">
                        <i data-feather="trash-2" class="me-1"></i>Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Initialize Feather Icons
        if (typeof feather !== 'undefined') {
            feather.replace();
        }

        // Copy to clipboard function
        function copyToClipboard(elementId) {
            var el = document.getElementById(elementId);
            if (!el) return;

            navigator.clipboard.writeText(el.value)
                .then(() => {
                    var modal = new bootstrap.Modal(document.getElementById('copySuccessModal'));
                    modal.show();
                    
                    // Re-initialize feather icons in modal
                    setTimeout(() => {
                        if (typeof feather !== 'undefined') {
                            feather.replace();
                        }
                    }, 100);
                })
                .catch(err => {
                    console.error("Failed to copy: ", err);
                    // Fallback for older browsers
                    el.select();
                    try {
                        document.execCommand('copy');
                        var modal = new bootstrap.Modal(document.getElementById('copySuccessModal'));
                        modal.show();
                        setTimeout(() => feather.replace(), 100);
                    } catch (e) {
                        alert('Unable to copy. Please manually copy the link.');
                    }
                });
        }

        // Wire up delete modal
        var deleteModal = document.getElementById('deleteConfirmModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var linkId = button.getAttribute('data-id');
                var form = document.getElementById('deleteForm');
                form.action = '/GuestLink/Delete/' + linkId;
                
                // Re-initialize feather icons in modal
                setTimeout(() => {
                    if (typeof feather !== 'undefined') {
                        feather.replace();
                    }
                }, 100);
            });
        }

        // Initialize feather icons on page load
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof feather !== 'undefined') {
                feather.replace();
            }
        });
    </script>
}
