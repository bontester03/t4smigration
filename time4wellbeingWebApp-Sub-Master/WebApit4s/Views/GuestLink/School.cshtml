@model WebApit4s.ViewModels.SchoolGuestLinkViewModel

@{
    ViewData["Title"] = $"{Model.SchoolName} - Guest Registration Links";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

<div class="col-md-6 d-flex align-items-center py-5">

     
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center py-4 rounded-top">
                    <h3 class="mb-0">@Model.SchoolName</h3>
                    <p class="text-light mb-0">Guest Registration Links</p>
                </div>

                <div class="card-body bg-white py-4 px-4">
                    <p class="text-center text-muted mb-4">
                        Please select the class you want to register for.
                    </p>

                    @if (Model.ClassLinks.Any())
                    {
                        <div class="list-group">
                            @foreach (var item in Model.ClassLinks)
                            {
                                <a href="@item.RegistrationUrl" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center shadow-sm mb-2 rounded-2 border-0">
                                    <div>
                                        <i class="bi bi-people-fill text-primary me-2"></i>
                                        <strong>@item.ClassName</strong>
                                    </div>
                                    <span class="badge bg-success text-white px-3 py-2">Register</span>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning text-center mt-4 mb-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            No active registration links available for this school.
                        </div>
                    }
                </div>

                <div class="card-footer text-center bg-light py-3">
                    <small class="text-muted">
                        Powered by <strong>Time4Sport</strong> – Helping children stay active and healthy.
                    </small>
                </div>
            </div>
        </div>
 
</div>
