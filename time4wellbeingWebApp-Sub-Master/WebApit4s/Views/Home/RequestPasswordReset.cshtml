@{
    ViewData["Title"] = "Request Password Reset";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

<div class="col-md-6 d-flex align-items-center py-5">
    <div class="container my-auto py-4 shadow-lg bg-white">
        <div class="row">
            <div class="col-11 col-lg-10 mx-auto">
                <h3 class="text-9 fw-600 text-center my-3">Forgot Password</h3>
                <div class="text-center text-gray-600 mt-3 mb-4">
                    Already have an account?
                    <a asp-action="Login" asp-controller="Home" class="text-green-700 fw-bold">Sign In</a>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form id="reset-form" method="post" asp-action="SendPasswordResetLink">
                    <div asp-validation-summary="All" class="text-danger text-center mb-3"></div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label text-dark fw-600" for="email">Registered Email Address</label>
                        <input type="email" class="form-control rounded-0" id="email" name="email" required placeholder="you@example.com">
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid my-4">
                        <button class="btn btn-success rounded-0" type="submit">Send Reset Link</button>
                    </div>
                </form>

                <!-- Terms Notice -->
                <p class="text-center text-muted text-2 mb-0">
                    By continuing, you agree to Time4Wellbeing’s
                    <a href="https://www.time4sportuk.com/terms">Terms</a> and
                    <a href="https://www.time4sportuk.com/terms">Privacy Policy</a>.
                </p>

                <div class="d-flex align-items-center my-4">
                    <hr class="flex-grow-1">
                    <span class="mx-2 text-2 text-muted">Stay fit & healthy</span>
                    <hr class="flex-grow-1">
                </div>
            </div>
        </div>
    </div>
</div>
