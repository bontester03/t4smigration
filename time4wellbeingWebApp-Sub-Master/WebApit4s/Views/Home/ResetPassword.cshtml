@model PasswordResetViewModel

@{
    ViewData["Title"] = "Update Password";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="col-md-6 d-flex align-items-center py-5">
    <div class="container my-auto py-4 shadow-lg bg-white">
        <div class="row">
            <div class="col-11 col-lg-10 mx-auto">
                <h3 class="text-9 fw-600 text-center my-3">Update Your Password</h3>

                <form method="post" asp-action="ResetPassword">
                    <div asp-validation-summary="All" class="text-danger text-center mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label text-dark fw-600" for="NewPassword">New Password</label>
                        <input asp-for="NewPassword" class="form-control rounded-0" type="password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-dark fw-600" for="ConfirmPassword">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control rounded-0" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid my-4">
                        <button type="submit" class="btn btn-success rounded-0">Update Password</button>
                    </div>
                </form>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success mt-3">@TempData["SuccessMessage"]</div>
                }
            </div>
        </div>
    </div>
</div>
