@model WebApit4s.Models.ChildGameTask
@{
    var assignedTasks = ViewBag.AssignedTasks as List<ChildGameTask>;
    var isEditMode = ViewBag.IsEditMode as bool? ?? false;
    var child = ViewBag.Child as WebApit4s.Models.Child;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="row">
    <a asp-action="RegisteredChildren" asp-controller="AdminDashboard" class="btn btn-secondary mb-3">
        <i class="fas fa-arrow-left me-1"></i> Back to Registered Children
    </a>

    <!-- Form Column -->
    <div class="col-lg-4">
        @if (child != null)
        {
            <div class="card mb-3 border-start border-3 border-success">
                <div class="card-body d-flex align-items-center">
                    <div>
                        <h5 class="mb-1">
                            <i class="fas fa-child me-1 text-primary"></i> @child.ChildName
                        </h5>
                        <p class="mb-0 text-muted">
                            <i class="fas fa-birthday-cake me-1 text-secondary"></i> Age: <strong>@child.Age</strong>
                        </p>
                        <p class="mb-0 text-muted">
                            <i class="fas fa-coins me-1 text-warning"></i> Coin Earning: <strong>@child.TotalPoints</strong>
                        </p>
                    </div>
                </div>
            </div>
        }

        <div class="card shadow mb-4">
            <div class="card-header @(isEditMode ? "bg-warning" : "bg-success") text-white">
                <i class="fas @(isEditMode ? "fa-edit" : "fa-plus-circle") me-1"></i>
                @(isEditMode ? "Edit Task" : "Assign New Task")
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ChildId" />

                    <div class="mb-3">
                        <label asp-for="GameTaskId" class="form-label"></label>
                        <select asp-for="GameTaskId" asp-items="ViewBag.GameTasks" class="form-select"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AssignedDate" class="form-label"></label>
                        <input asp-for="AssignedDate" class="form-control" type="date" />
                    </div>

                    <div class="form-check mb-3">
                        <input type="checkbox" asp-for="IsRecurringDaily" class="form-check-input" />
                        <label asp-for="IsRecurringDaily" class="form-check-label">Repeat Daily</label>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CompletedDate" class="form-label"></label>
                        <input asp-for="CompletedDate" class="form-control" type="date" />
                    </div>

                    <div class="d-flex justify-content-between">
                        <button type="submit" class="btn @(isEditMode ? "btn-warning" : "btn-success")">
                            <i class="fas @(isEditMode ? "fa-save" : "fa-plus") me-1"></i>
                            @(isEditMode ? "Update Task" : "Assign Task")
                        </button>
                        @if (isEditMode)
                        {
                            <a asp-action="Create" asp-route-childId="@Model.ChildId" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i> Cancel Edit
                            </a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Table Column -->
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <span><i class="fas fa-tasks me-1"></i> Assigned Tasks</span>

                <!-- Bulk Delete Button -->
                <form id="adminBulkDeleteForm" asp-action="BulkDelete" asp-controller="AdminChildGameTask" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="childId" value="@child?.Id" />
                    <input type="hidden" name="taskIdsCsv" id="taskIdsCsv" />
                    <button type="button" id="bulkDeleteBtn" class="btn btn-danger btn-sm delete-trigger" data-form="adminBulkDeleteForm" disabled>
                        <i class="fas fa-trash-alt me-1"></i> Delete Selected
                    </button>
                </form>

            </div>

            <div class="card-body table-responsive">
                @if (assignedTasks != null && assignedTasks.Any())
                {
                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th style="width:36px;"><input type="checkbox" id="selectAll" /></th>
                                <th>Task</th>
                                <th>Assigned</th>
                                <th>Completed</th>
                                <th>Status</th>
                                <th>Recurring</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in assignedTasks)
                            {
                                var isExpired = !task.IsCompleted && DateTime.UtcNow > task.ExpiryDate;

                                <tr>
                                    <td>
                                    <td>
                                        <input type="checkbox" class="row-check" value="@task.Id" />
                                    </td>
                                    </td>
                                    <td>@task.GameTask?.Title</td>
                                    <td>@task.AssignedDate.ToShortDateString()</td>
                                    <td>@(task.IsExpired ? "Expired" : (task.CompletedDate?.ToShortDateString() ?? "Not Completed"))</td>
                                    <td>
                                        @if (task.IsCompleted)
                                        {
                                            <span class="badge bg-success">Completed</span>
                                        }
                                        else if (isExpired)
                                        {
                                            <span class="badge bg-danger">Expired</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                    </td>
                                    <td>
                                        @(task.IsRecurringDaily? Html.Raw("<span class='badge bg-info'>Yes</span>") : Html.Raw("<span class='badge bg-secondary'>No</span>"))
                                    </td>
                                    <td class="d-flex gap-1">
                                        <!-- Edit Button -->
                                        <a asp-action="Create" asp-route-childId="@task.ChildId" asp-route-editTaskId="@task.Id" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>

                                        <!-- Single Delete -->
                                        <form asp-action="Delete" asp-route-id="@task.Id" asp-route-childId="@task.ChildId" method="post" id="deleteForm-@task.Id" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-sm btn-danger delete-trigger" data-form="deleteForm-@task.Id">
                                                <i class="fas fa-trash-alt"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No tasks assigned yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">Are you sure you want to delete the selected task(s)?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Bulk select checkboxes
        (function () {
            const selectAll = document.getElementById('selectAll');
            const checks = () => Array.from(document.querySelectorAll('.row-check'));
            const bulkBtn = document.getElementById('bulkDeleteBtn');

            function updateBulkDeleteState() {
                bulkBtn.disabled = !checks().some(c => c.checked);
            }

            if (selectAll) {
                selectAll.addEventListener('change', function () {
                    checks().forEach(c => c.checked = selectAll.checked);
                    updateBulkDeleteState();
                });
            }

            checks().forEach(c => c.addEventListener('change', function () {
                const allChecked = checks().every(x => x.checked);
                const anyChecked = checks().some(x => x.checked);
                if (selectAll) {
                    selectAll.checked = allChecked;
                    selectAll.indeterminate = !allChecked && anyChecked;
                }
                updateBulkDeleteState();
            }));

            updateBulkDeleteState();
        })();

        // Delete confirmation modal logic
              document.addEventListener("DOMContentLoaded", function () {
            const bulkBtn = document.getElementById('bulkDeleteBtn');
            const csvField = document.getElementById('taskIdsCsv');
            const selectAll = document.getElementById('selectAll');
            const checks = () => Array.from(document.querySelectorAll('.row-check'));

            // Enable/disable bulk delete
            function updateBulkDeleteState() {
                bulkBtn.disabled = !checks().some(c => c.checked);
            }

            if (selectAll) {
                selectAll.addEventListener('change', function () {
                    checks().forEach(c => c.checked = selectAll.checked);
                    updateBulkDeleteState();
                });
            }

            checks().forEach(c => c.addEventListener('change', updateBulkDeleteState));
            updateBulkDeleteState();

            // Modal delete logic
            let targetFormId = null;
            const modal = new bootstrap.Modal(document.getElementById("deleteConfirmModal"));
            const confirmBtn = document.getElementById("confirmDeleteBtn");

            document.querySelectorAll(".delete-trigger").forEach(btn => {
                btn.addEventListener("click", function () {
                    targetFormId = this.getAttribute("data-form");

                    if (targetFormId === "adminBulkDeleteForm") {
                        const selectedIds = checks().filter(c => c.checked).map(c => c.value);
                        csvField.value = selectedIds.join(",");
                    }

                    modal.show();
                });
            });

            confirmBtn.addEventListener("click", function () {
                if (targetFormId) {
                    document.getElementById(targetFormId).submit();
                }
            });
        });

    </script>
}
