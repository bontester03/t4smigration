@model WebApit4s.Models.WeeklyMeasurements

@{
    ViewData["Title"] = "Add Weekly Measurement";
    var isEditable = (int?)ViewBag.ReferralTypeId == 1;
}

<div class="card mb-4">
    <div class="card-body">
        <p class="alert alert-info">
            For the next 12 weeks we are going to track your centile score. 
        </p>

        @if (isEditable)
        {
            <form asp-action="Create" asp-controller="WeeklyMeasurements" method="post">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="ChildId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Age" class="form-label"></label>
                    <input asp-for="Age" class="form-control" />
                    <span asp-validation-for="Age" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Height" class="form-label"></label>
                    <input asp-for="Height" class="form-control" />
                    <span asp-validation-for="Height" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Weight" class="form-label"></label>
                    <input asp-for="Weight" class="form-control" />
                    <span asp-validation-for="Weight" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CentileScore" class="form-label" data-bs-toggle="tooltip"
                           title="Use the NHS calculator to find out your child’s centile score.">
                        Centile Score <i class="fas fa-info-circle text-muted"></i>
                    </label>
                    <input asp-for="CentileScore" class="form-control" />
                    <span asp-validation-for="CentileScore" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DateRecorded" class="form-label"></label>
                    <input asp-for="DateRecorded" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
                    <span asp-validation-for="DateRecorded" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </form>

        }
        else
        {
            <div class="alert alert-warning">
                You are currently on a referral pathway that does not allow manual measurement submissions.
                Please contact your health advisor if this seems incorrect.
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (el) {
                return new bootstrap.Tooltip(el);
            });
        });
    </script>
}


<!-- Validation Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
