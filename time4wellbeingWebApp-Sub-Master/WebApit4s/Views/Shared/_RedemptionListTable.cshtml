@model IEnumerable<WebApit4s.Models.ParentRewardRedemption>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info mb-0">
        <i class="fas fa-info-circle me-1"></i> No requested items.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Child</th>
                    <th>Reward</th>
                    <th style="width:120px;">Cost</th>
                    <th style="width:140px;">Status</th>
                    <th style="width:180px;">Requested</th>
                    <th style="width:240px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.OrderBy(x => x.RequestedUtc))
                {
                    <tr>
                        <td class="fw-semibold">
                            <i class="fas fa-child me-1 text-primary"></i>@r.Child?.ChildName
                        </td>
                        <td><div class="fw-semibold">@r.ParentReward?.Title</div></td>
                        <td><span class="badge bg-info"><i class="fas fa-coins me-1"></i>@r.CoinCostAtPurchase</span></td>
                        <td><span class="badge bg-warning">Requested</span></td>
                        <td>@r.RequestedUtc.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                        <td class="text-nowrap">
                            <form asp-action="ApproveRedemption" asp-controller="Parent" method="post" class="d-inline" id="approveForm-@r.Id">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="button" class="btn btn-success btn-sm action-trigger" data-form="approveForm-@r.Id" data-action="approve">
                                    <i class="fas fa-check"></i> Approve
                                </button>
                            </form>
                            <form asp-action="RejectRedemption" asp-controller="Parent" method="post" class="d-inline" id="rejectForm-@r.Id">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="button" class="btn btn-danger btn-sm action-trigger" data-form="rejectForm-@r.Id" data-action="reject">
                                    <i class="fas fa-times"></i> Reject
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
