@using WebApit4s.Identity
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Time4Wellbeing</title>

    <link href="~/css/app.css" rel="stylesheet" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/images/time4sport-logo.png" />
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/js/all.min.js" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/feather-icons/4.29.0/feather.min.js" crossorigin="anonymous"></script>

    <style>
        body {
            overflow-x: hidden;
        }

        #layoutSidenav {
            display: flex;
            flex-direction: row;
            min-height: 100vh;
        }

        #layoutSidenav_nav {
            width: 250px;
            background-color: #fff;
            z-index: 1000;
        }

        #layoutSidenav_content {
            flex-grow: 1;
            min-width: 0;
            overflow-x: hidden;
            background-color: #f8f9fa;
        }

        
        @@media (max-width: 767.98px) {
            #layoutSidenav_nav

        {
            position: absolute;
            left: -250px;
            top: 0;
            height: 100%;
            width: 250px;
            background-color: #fff;
            z-index: 1030;
            transition: all 0.3s ease;
        }

        body.sidebar-open #layoutSidenav_nav {
            left: 0;
        }

        #layoutSidenav {
            position: relative;
        }

        }
    </style>
</head>

<body class="nav-fixed">
    <!-- Top Navbar -->
    <nav class="topnav navbar navbar-expand shadow navbar-light bg-white">
        <button class="btn btn-icon btn-transparent-dark me-2" id="sidebarToggle"><i data-feather="menu"></i></button>
        <a class="navbar-brand pe-3 ps-2" asp-controller="Dashboard" asp-action="LandingPage">Time4Wellbeing</a>

        @* <form class="form-inline me-auto d-none d-lg-block me-3">
            <div class="input-group input-group-joined input-group-solid">
                <input class="form-control pe-0" type="search" placeholder="Search" />
                <div class="input-group-text"><i data-feather="search"></i></div>
            </div>
        </form> *@

        <ul class="navbar-nav align-items-center ms-auto">
            <li class="nav-item dropdown no-caret d-sm-block me-3 dropdown-notifications">
                <a class="btn btn-icon btn-transparent-dark dropdown-toggle" id="navbarDropdownAlerts" href="#" data-bs-toggle="dropdown">
                    <i data-feather="bell"></i>
                    <span id="notificationCount" class="badge bg-danger rounded-pill d-none"></span>
                </a>
                <div class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="navbarDropdownAlerts">
                    <h6 class="dropdown-header"><i class="me-2" data-feather="bell"></i> Alerts Center</h6>
                    <div id="notificationList">
                        <p class="text-center p-2 text-muted">Loading notifications...</p>
                    </div>
                    <a class="dropdown-item dropdown-notifications-footer" asp-controller="Dashboard" asp-action="Notifications">View All Notifications</a>
                </div>
            </li>

            <li class="nav-item dropdown no-caret dropdown-user me-3 me-lg-4">
                <a class="btn btn-icon btn-transparent-dark dropdown-toggle"
                   id="navbarDropdownUserImage"
                   href="#"
                   role="button"
                   data-bs-toggle="dropdown"
                   aria-expanded="false">

                    <!-- Navbar (small) avatar -->
                    <img class="dropdown-user-img"
                         style="width: 32px; height: 32px; object-fit: cover;"
                         src="@ViewBag.ChildAvatar"
                         alt="Child Avatar" />
                </a>

                <div class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="navbarDropdownUserImage">
                    <h6 class="dropdown-header d-flex align-items-center">

                        <!-- Dropdown header avatar (same style/size as above) -->
                        <img class="dropdown-user-img me-2"
                             style="width: 32px; height: 32px; object-fit: cover;"
                             src="@ViewBag.ChildAvatar"
                             alt="Child Avatar" />

                        <div class="ms-2">
                            <div class="dropdown-user-details-name">@ViewBag.ChildName</div>
                            <div class="dropdown-user-details-email">@ViewBag.UserEmail</div>
                        </div>
                    </h6>

                    <div class="dropdown-divider"></div>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item p-0">
                            <button type="submit" class="btn btn-link text-start w-100 text-dark">
                                <div class="dropdown-item-icon"><i data-feather="log-out"></i></div>
                                Logout
                            </button>
                        </form>
                    }
                </div>
            </li>

        </ul>
    </nav>

    <!-- Main Layout -->
    <div id="layoutSidenav">
        <!-- Sidebar -->
        <div id="layoutSidenav_nav">
            <nav class="sidenav shadow-right sidenav-light d-flex flex-column">
                <div class="sidenav-menu flex-grow-1">
                    <div class="nav accordion" id="accordionSidenav">
                        <div class="sidenav-menu-heading">Core</div>

                        <a class="nav-link collapsed" data-bs-toggle="collapse" data-bs-target="#collapseDashboards" aria-expanded="false" aria-controls="collapseDashboards">
                            <div class="nav-link-icon"><i data-feather="activity"></i></div>
                            Additional Features
                            <div class="sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <!-- Collapsible submenu -->
                        <div class="collapse" id="collapseDashboards" data-bs-parent="#sidenavAccordion">
                            <nav class="sidenav-menu-nested nav">

                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "LandingPage" ? "text-primary fw-bold" : "")"
                                   asp-controller="Dashboard" asp-action="LandingPage">
                                    <div class="nav-link-icon"><i class="fa-solid fa-arrow-right"></i></div> Go to Landing Page
                                </a>

                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "AIGoal" ? "text-primary fw-bold" : "")"
                                   asp-controller="AIGoal" asp-action="Generate">
                                    <div class="nav-link-icon"><i class="fas fa-lightbulb"></i></div> Get AI Goal
                                </a>
                             



                            </nav>
                        </div>

                        <nav class="sidenav mt-1">
                            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "ParentDashboard" ? "text-primary fw-bold" : "")"
                               asp-controller="Parent" asp-action="Dashboard">
                                <div class="nav-link-icon"><i class="fas fa-user-friends"></i></div> Parent Dashboard
                            </a>

                            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "AddChildWithScore" ? "text-primary fw-bold" : "")"
                               asp-controller="Dashboard" asp-action="AddChildWithScore">
                                <div class="nav-link-icon"><i class="fa fa-child"></i></div> Add Another Child
                            </a>

                            <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "SelectChild" ? "text-primary fw-bold" : "")"
                               asp-controller="Dashboard" asp-action="SelectChild">
                                <div class="nav-link-icon"><i class="fa-solid fa-children"></i></div> Swap Child
                            </a>

                        
                            <!-- New Child-related Buttons -->
                            <div class="mt-3 border-top pt-3">
                                <!-- Existing Nav Links -->
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Profile" ? "text-primary fw-bold" : "")" asp-action="Index" asp-controller="Dashboard">
                                    <div class="nav-link-icon"><i data-feather="user"></i></div> Profile
                                </a>
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Goal" ? "text-primary fw-bold" : "")" asp-action="Goal" asp-controller="Dashboard">
                                    <div class="nav-link-icon"><i data-feather="target"></i></div> Tracking Goal
                                </a>
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Questionnaire" ? "text-primary fw-bold" : "")" asp-action="Questionnaire" asp-controller="Dashboard">
                                    <div class="nav-link-icon"><i data-feather="list"></i></div> Questionnaire
                                </a>
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Measurement" ? "text-primary fw-bold" : "")" asp-action="Measurement" asp-controller="Dashboard">
                                    <div class="nav-link-icon"><i data-feather="activity"></i></div> Measurement
                                </a>
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Suggestions" ? "text-primary fw-bold" : "")" asp-action="Suggestions" asp-controller="Dashboard">
                                    <div class="nav-link-icon"><i data-feather="video"></i></div> Video Suggestions
                                </a>
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "GameTask" ? "text-primary fw-bold" : "")" asp-controller="ChildGameTask" asp-action="Index">
                                    <div class="nav-link-icon"><i data-feather="check-square"></i></div> Game & Tasks
                                </a>
                               @*  <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "MyPoints" ? "text-primary fw-bold" : "")" asp-controller="UserPointHistory" asp-action="MyPoints">
                                    <div class="nav-link-icon"><i class="fas fa-star"></i></div> My Points
                                </a>
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "MyRedemptions" ? "text-primary fw-bold" : "")"
                                   asp-controller="Dashboard"
                                   asp-action="MyRedemptions">
                                    <div class="nav-link-icon"><i class="fas fa-gift"></i></div> My Rewards
                                </a>
                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "AvailableRewards" ? "text-primary fw-bold" : "")"
                                   asp-controller="Dashboard"
                                   asp-action="AvailableRewards">
                                    <div class="nav-link-icon"><i class="fas fa-gift"></i></div> Available Rewards
                                </a>



                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Notification" ? "text-primary fw-bold" : "")" asp-action="Notifications" asp-controller="Dashboard">
                                    <div class="nav-link-icon"><i data-feather="bell"></i></div> Notification
                                </a> *@

                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "VideoReward" ? "text-primary fw-bold" : "")"
                                   asp-controller="VideoReward" asp-action="List">
                                    <div class="nav-link-icon"><i class="fas fa-video"></i></div> Watch &amp; Earn Coins
                                </a>


                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "MedicalHistory" ? "text-primary fw-bold" : "")"
                                   asp-action="MedicalHistory" asp-controller="Dashboard">
                                    <div class="nav-link-icon"><i data-feather="activity"></i></div> Medical History
                                </a>


                                <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Feedback" ? "text-primary fw-bold" : "")" asp-action="Feedback" asp-controller="Dashboard">
                                    <div class="nav-link-icon"><i class="fa fa-comment-dots"></i></div> Feedback
                                </a>
                            

                            </div>
                        </nav>

                    </div>
                </div>

              <div class="sidenav-footer mt-auto">
    <div class="sidenav-footer-content">
        <div class="sidenav-footer-subtitle">Logged in as:</div>
        <div class="sidenav-footer-title text-success fw-bold">@ViewBag.ChildName</div>
    </div>
</div>

            </nav>
        </div>

        <!-- Page Content -->
        <div id="layoutSidenav_content">
            <main class="p-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script>
        document.getElementById("sidebarToggle").addEventListener("click", function () {
            document.body.classList.toggle("sidebar-open");
        });

        document.addEventListener("DOMContentLoaded", function () {
            const notificationList = document.getElementById("notificationList");
            const notificationCount = document.getElementById("notificationCount");

            fetch('/Dashboard/GetUserNotifications')
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.notifications.length > 0) {
                        notificationList.innerHTML = "";
                        data.notifications.forEach(notification => {
                            const item = document.createElement("a");
                            item.className = "dropdown-item dropdown-notifications-item";
                            item.innerHTML = `
                                <div class="dropdown-notifications-item-icon bg-warning">
                                    <i data-feather="bell"></i>
                                </div>
                                <div class="dropdown-notifications-item-content">
                                    <div class="dropdown-notifications-item-content-details">${notification.createdAt}</div>
                                    <div class="dropdown-notifications-item-content-text">${notification.message}</div>
                                </div>`;
                            notificationList.appendChild(item);
                        });

                        notificationCount.textContent = data.notifications.length;
                        notificationCount.classList.remove("d-none");
                        feather.replace();
                    } else {
                        notificationList.innerHTML = `<p class="text-center p-2 text-muted">No unread notifications</p>`;
                        notificationCount.classList.add("d-none");
                    }
                })
                .catch(error => {
                    console.error("Error loading notifications:", error);
                    notificationList.innerHTML = `<p class="text-center p-2 text-danger">Error loading notifications</p>`;
                });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
