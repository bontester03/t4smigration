<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Time4Wellbeing</title>

    <link href="~/css/app.css" rel="stylesheet" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/images/time4sport-logo.png" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/js/all.min.js" crossorigin="anonymous" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/feather-icons/4.29.0/feather.min.js" crossorigin="anonymous"></script>

    <style>
        body {
            overflow-x: hidden;
        }

        .table-responsive {
            overflow-x: auto;
        }

        main {
            padding: 1rem;
        }

        .card {
            word-wrap: break-word;
        }
    </style>
</head>
<body class="nav-fixed">
    <!-- Top Navigation -->
    <nav class="topnav navbar navbar-expand shadow navbar-light bg-white justify-content-between" id="sidenavAccordion">
        <button class="btn btn-icon btn-transparent-dark me-2" id="sidebarToggle"><i data-feather="menu"></i></button>
        <a class="navbar-brand pe-3 ps-4 ps-lg-2" asp-controller="AdminDashboard" asp-action="Index">Time4Wellbeing</a>

    @*     <form class="form-inline d-none d-lg-block me-3">
            <div class="input-group input-group-joined input-group-solid">
                <input class="form-control pe-0" type="search" placeholder="Search" aria-label="Search" />
                <div class="input-group-text"><i data-feather="search"></i></div>
            </div>
        </form> *@

        <ul class="navbar-nav align-items-center ms-auto">
            <!-- Alerts and Messages (optional) -->
            <!-- ...existing dropdowns can stay here... -->
            <!-- User Dropdown -->
            <li class="nav-item dropdown no-caret dropdown-user me-3 me-lg-4">
                <a class="btn btn-icon btn-transparent-dark dropdown-toggle" id="navbarDropdownUserImage" href="#" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <img class="img-fluid" src="~/images/profile-1.png" />
                </a>
                <div class="dropdown-menu dropdown-menu-end border-0 shadow animated--fade-in-up" aria-labelledby="navbarDropdownUserImage">
                    <h6 class="dropdown-header d-flex align-items-center">
                        <img class="dropdown-user-img" src="~/images/profile-1.png" />
                        <div class="dropdown-user-details">
                            <div class="dropdown-user-details-name">@ViewBag.ChildName</div>
                            <div class="dropdown-user-details-email">@ViewBag.UserEmail</div>
                        </div>
                    </h6>
                    <div class="dropdown-divider"></div>
                    @if (User.Identity.IsAuthenticated)
                    {
        <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item p-0">
            <button type="submit" class="btn btn-link text-start w-100 text-dark">
                <div class="dropdown-item-icon"><i data-feather="log-out"></i></div>
                Logout
            </button>
        </form>
                    }

                </div>
            </li>
        </ul>
    </nav>

    <!-- Main Layout -->
    <div id="layoutSidenav" class="d-flex">
        <!-- Sidebar -->
        <div id="layoutSidenav_nav">
            <nav class="sidenav shadow-right sidenav-light">
                <div class="sidenav-menu">
                    <div class="nav accordion" id="accordionSidenav">
                        <div class="sidenav-menu-heading">Core</div>

                        <a class="nav-link collapsed" data-bs-toggle="collapse" href="#collapseEntities" aria-expanded="false">
                            <div class="nav-link-icon"><i data-feather="settings"></i></div>
                            Manage Entities
                            <div class="sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse" id="collapseEntities">
                            <nav class="sidenav-menu-nested nav accordion">
                                <a class="nav-link" asp-controller="AdminDashboard" asp-action="ManageClasses">Manage Classes</a>
                                <a class="nav-link" asp-controller="AdminDashboard" asp-action="ManageSchools">Manage Schools</a>
                                <a class="nav-link" asp-controller="AdminDashboard" asp-action="ManageReferralTypes">Manage Referral</a>
                                <a class="nav-link" asp-controller="AdminDashboard" asp-action="ManageConsentQuestions">Manage ConsentQuestions</a>
                                <a class="nav-link" asp-controller="Account" asp-action="Create">Add User</a>
                        
                            </nav>
                        </div>


                        <!-- Pages -->
                        <nav class="sidenav mt-1">
                            <a class="nav-link" asp-controller="AdminDashboard" asp-action="Index">
                                <div class="nav-link-icon"><i data-feather="user"></i></div>
                                Landing Page
                            </a>
                            <a class="nav-link" asp-controller="AdminDashboard" asp-action="RegisteredChildren">
                                <div class="nav-link-icon"><i data-feather="target"></i></div>
                                View Registered Children
                            </a>
                            <a class="nav-link" asp-controller="AdminDashboard" asp-action="AllHealthScores">
                                <div class="nav-link-icon"><i data-feather="list"></i></div>
                                View all Questionnaire
                            </a>
                            <a class="nav-link" asp-controller="AdminDashboard" asp-action="WeeklyMeasurementsAdmin">
                                <div class="nav-link-icon"><i data-feather="activity"></i></div>
                                View all Measurement
                            </a>
                            <a class="nav-link" asp-controller="AdminDashboard" asp-action="RecentActivity">
                                <div class="nav-link-icon"><i data-feather="video"></i></div>
                                View all Activity
                            </a>
                            <a class="nav-link" asp-controller="AdminDashboard" asp-action="SendNotification">
                                <div class="nav-link-icon"><i data-feather="bell"></i></div>
                                Notification
                            </a>
                            <a class="nav-link" asp-controller="AdminDashboard" asp-action="AllConsentAnswers">
                                <div class="nav-link-icon"><i data-feather="file-text"></i></div>
                                View Consent Answers
                            </a>
                            <a class="nav-link" asp-controller="AdminDashboard" asp-action="ViewRegistrationReminders">
                                    <div class="nav-link-icon"><i data-feather="clock"></i></div>
                                     Reminder Email Logs
                                         </a>

                        </nav>
                    </div>
                </div>

                <div class="sidenav-footer mt-auto">
                    <div class="sidenav-footer-content">
                        <div class="sidenav-footer-subtitle">Logged in as:</div>
                        <div class="sidenav-footer-title">@ViewBag.ChildName</div>
                    </div>
                </div>
            </nav>
        </div>

        <!-- Page Content -->
        <div id="layoutSidenav_content">
            <main>
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/js/app.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
