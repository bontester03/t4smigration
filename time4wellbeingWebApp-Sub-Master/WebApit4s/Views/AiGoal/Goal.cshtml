@{
    ViewData["Title"] = "AI Generated Goal";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="card shadow-sm mt-4">
    <div class="card-header bg-success text-white">
        <i class="fa-solid fa-brain-circuit me-2"></i> Personalised Goal for @ViewBag.ChildName
    </div>
    <div class="card-body">
        <p class="mb-2"><strong>Focus Area:</strong> <span class="text-primary">@ViewBag.Category</span></p>

        <div class="alert alert-success" role="alert">
            <i class="fa-solid fa-bullseye me-2"></i> <strong>AI-Generated Goal:</strong>
            <blockquote class="blockquote mt-2 mb-0">
                <p class="mb-0">@ViewBag.Goal</p>
            </blockquote>
        </div>

        <div class="text-end mt-4">
            <a href="@Url.Action("LandingPage", "Dashboard")" class="btn btn-outline-primary">
                <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>
