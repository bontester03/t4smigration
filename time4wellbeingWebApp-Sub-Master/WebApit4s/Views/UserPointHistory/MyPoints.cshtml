@model IEnumerable<WebApit4s.Models.UserPointHistory>

@{
    ViewData["Title"] = "My Child's Points";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-success d-flex justify-content-between align-items-center">
        <h5 class="mb-0 text-white">
            <i class="fas fa-coins me-2"></i> My Child's Points
        </h5>
    </div>


    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                <i class="fas fa-info-circle me-1"></i>
                No point history found for this child.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 10%">Change</th>
                            <th style="width: 15%">Balance</th>
                            <th style="width: 20%">Reason</th>
                            <th style="width: 30%">Notes</th>
                            <th style="width: 25%">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge rounded-pill @(item.Delta >= 0 ? "bg-success" : "bg-danger")">
                                        @((item.Delta >= 0 ? "+" : "") + item.Delta)
                                    </span>
                                </td>
                                <td>
                                    <span class="fw-bold text-dark">
                                        @item.BalanceAfter
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        @item.Reason
                                    </span>
                                </td>
                                <td>@item.Notes</td>
                                <td><i class="far fa-clock me-1 text-muted"></i>@item.CreatedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
