@model WebApit4s.Models.PersonalDetails

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit</h1>

<h4>PersonalDetails</h4>
<hr />
<div class="col-xl-8">
    <!-- Account details card-->
    <div class="card mb-4">
        <div class="card-header">Personal Details</div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />

                <!-- Form Row-->
                <div class="row gx-3 mb-3">
                    <!-- Form Group (Parent/Guardian Name)-->
                    <div class="col-md-12">
                        <label class="small mb-1" asp-for="ParentGuardianName">Parent/Guardian Name</label>
                        <input class="form-control" asp-for="ParentGuardianName" placeholder="Enter parent or guardian name" />
                        <span asp-validation-for="ParentGuardianName" class="text-danger"></span>
                    </div>
                </div>

                <!-- Form Row-->
                <div class="row gx-3 mb-3">
                    <!-- Form Group (Relationship to Child)-->
                    <div class="col-md-6">
                        <label class="small mb-1" asp-for="RelationshipToChild">Relationship to Child</label>
                        <input class="form-control" asp-for="RelationshipToChild" placeholder="Enter relationship" />
                        <span asp-validation-for="RelationshipToChild" class="text-danger"></span>
                    </div>

                    <!-- Form Group (Phone Number)-->
                    <div class="col-md-6">
                        <label class="small mb-1" asp-for="TeleNumber">Phone Number</label>
                        <input class="form-control" asp-for="TeleNumber" placeholder="Enter phone number" type="tel" />
                        <span asp-validation-for="TeleNumber" class="text-danger"></span>
                    </div>
                </div>

                <!-- Form Group (Email)-->
                <div class="mb-3">
                    <label class="small mb-1" asp-for="Email">Email</label>
                    <input class="form-control" asp-for="Email" placeholder="Enter email address" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- Form Row-->
                <div class="row gx-3 mb-3">
                    <!-- Form Group (Postcode)-->
                    <div class="col-md-6">
                        <label class="small mb-1" asp-for="Postcode">Postcode</label>
                        <input class="form-control" asp-for="Postcode" placeholder="Enter postcode" />
                        <span asp-validation-for="Postcode" class="text-danger"></span>
                    </div>

                    <!-- Form Group (GP Practice)-->
                 
                </div>

                <!-- Form Group (UserId)-->
                <div class="mb-3">
                    <label class="small mb-1" asp-for="UserId">User</label>
                    <select asp-for="UserId" class="form-control" asp-items="ViewBag.UserId"></select>
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <!-- Save changes button-->
                <button class="btn btn-primary" type="submit">Save changes</button>
            </form>
        </div>
    </div>
</div>


<div>
    <a asp-action="Index">Back to List</a>
</div>
