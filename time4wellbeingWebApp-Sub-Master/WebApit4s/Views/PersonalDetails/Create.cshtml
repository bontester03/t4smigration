@model WebApit4s.Models.PersonalDetails

@{
    ViewData["Title"] = "Personal Details";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
    var requiresSchoolSelection = ViewBag.RequiresSchoolSelection as bool? ?? false;
}

<style>
    .personal-details-card {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(10px);
        max-width: 700px;
        width: 100%;
        margin: 0 auto;
    }
    .personal-details-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        padding: 2rem 1.5rem;
        text-align: center;
        color: white;
        border-radius: 20px 20px 0 0;
    }
    .personal-details-header h3 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .personal-details-header p {
        font-size: 0.95rem;
        opacity: 0.95;
        margin: 0;
    }
    .personal-details-body {
        padding: 2.5rem 2rem;
    }
    .form-control-modern {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        padding-left: 2.75rem;
        font-size: 0.95rem;
        transition: all 0.3s;
        position: relative;
        background-color: white;
    }
    .form-control-modern:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.15);
    }
    .form-select-modern {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        padding-left: 2.75rem;
        font-size: 0.95rem;
        transition: all 0.3s;
        position: relative;
        background-color: white;
    }
    .form-select-modern:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.15);
    }
    .form-label-modern {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .input-icon {
        position: relative;
    }
    .input-icon i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        z-index: 10;
        pointer-events: none;
    }
    .btn-modern {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        border-radius: 10px;
        padding: 0.75rem;
        font-size: 1rem;
        font-weight: 600;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
    }
    .btn-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.5);
        background: linear-gradient(135deg, #059669 0%, #047857 100%);
        color: white;
    }
    .progress-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.2);
        padding: 0.4rem 0.9rem;
        border-radius: 50px;
        margin-bottom: 0.75rem;
        backdrop-filter: blur(10px);
        font-size: 0.85rem;
    }
    .info-box {
        background: #f0fdf4;
        border-left: 4px solid #10b981;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        border-right: 1px solid #d1fae5;
        border-top: 1px solid #d1fae5;
        border-bottom: 1px solid #d1fae5;
    }
    .info-box p {
        margin: 0;
        color: #065f46;
        font-size: 0.9rem;
        line-height: 1.6;
    }
    .info-box i {
        color: #10b981;
    }
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 1.25rem 0;
    }
    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #e0e0e0;
    }
    .divider span {
        padding: 0 1rem;
        color: #9ca3af;
        font-size: 0.85rem;
        font-weight: 500;
    }
    .step-progress {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1.5rem;
    }
    .step-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #d1fae5;
        transition: all 0.3s;
    }
    .step-dot.active {
        width: 30px;
        border-radius: 5px;
        background: #10b981;
    }
</style>

<style media="(max-width: 768px)">
    .personal-details-body {
        padding: 2rem 1.5rem;
    }
</style>

<div class="col-md-6 d-flex align-items-center py-5">
<div class="container my-auto">
    <div class="row">
        <div class="col-11 col-lg-10 mx-auto">
            <div class="personal-details-card">
                    <!-- Header -->
                    <div class="personal-details-header">
                        <div class="progress-badge">
                            <i class="fas fa-clipboard-list me-2"></i>Step 2 of 3
                        </div>
                        <h3 class="mb-1">Personal Details</h3>
                        <p>Tell us about your school and guardian information</p>
                    </div>

                    <!-- Body -->
                    <div class="personal-details-body">
                        <form asp-action="Create" method="post">
                            <!-- Validation Summary -->
                            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                            {
                                <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-3" role="alert"></div>
                            }

                            <!-- Alert Messages -->
                            @if (TempData["Error"] != null)
                            {
                                <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    @TempData["Error"]
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                            }

                            @if (TempData["Success"] != null)
                            {
                                <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                                    <i class="fas fa-check-circle me-2"></i>
                                    @TempData["Success"]
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                            }

                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label class="form-label-modern" asp-for="RelationshipToChild">
                                        <i class="fas fa-users me-2"></i>Relationship to Child
                                    </label>
                                    <div class="input-icon">
                                        <i class="fas fa-heart"></i>
                                        <select asp-for="RelationshipToChild" asp-items="ViewBag.RelationshipOptions" class="form-select form-select-modern">
                                            <option value="">-- Select Relationship --</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="RelationshipToChild" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Parent/Guardian Name and Phone -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label-modern" asp-for="ParentGuardianName">
                                        <i class="fas fa-user me-2"></i>Parent/Guardian Name
                                    </label>
                                    <div class="input-icon">
                                        <i class="fas fa-user-tie"></i>
                                        <input asp-for="ParentGuardianName" class="form-control form-control-modern" placeholder="Full name" />
                                    </div>
                                    <span asp-validation-for="ParentGuardianName" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label-modern" asp-for="TeleNumber">
                                        <i class="fas fa-phone me-2"></i>Phone Number
                                    </label>
                                    <div class="input-icon">
                                        <i class="fas fa-mobile-alt"></i>
                                        <input asp-for="TeleNumber" class="form-control form-control-modern" placeholder="07XXX XXXXXX" type="tel" />
                                    </div>
                                    <span asp-validation-for="TeleNumber" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="mb-3">
                                <label class="form-label-modern" asp-for="Email">
                                    <i class="fas fa-envelope me-2"></i>Email Address
                                </label>
                                <div class="input-icon">
                                    <i class="far fa-envelope"></i>
                                    <input asp-for="Email" class="form-control form-control-modern" placeholder="you@example.com" type="email" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <!-- Postcode -->
                            <div class="mb-4">
                                <label class="form-label-modern" asp-for="Postcode">
                                    <i class="fas fa-map-marker-alt me-2"></i>Postcode
                                </label>
                                <div class="input-icon">
                                    <i class="fas fa-map-pin"></i>
                                    <input asp-for="Postcode" class="form-control form-control-modern text-uppercase" placeholder="SW1A 1AA" />
                                </div>
                                <span asp-validation-for="Postcode" class="text-danger small"></span>
                            </div>

                            <!-- Submit Button -->
                            <div class="d-grid my-4">
                                <button class="btn btn-modern" type="submit">
                                    <i class="fas fa-arrow-right me-2"></i>Save and Continue
                                </button>
                            </div>
                        </form>

                        <!-- Progress Indicator -->
                        <div class="divider">
                            <span><i class="fas fa-list-ol me-2"></i>Registration Progress</span>
                        </div>

                        <div class="step-progress">
                            <div class="step-dot"></div>
                            <div class="step-dot active"></div>
                            <div class="step-dot"></div>
                        </div>

                        <p class="text-center text-muted small mt-2 mb-0">
                            Step 2 of 3 - Almost there!
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
