@model IEnumerable<WebApit4s.Models.GameTask>
@using System.Linq

@{
    ViewData["Title"] = "Game Tasks";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Game Tasks</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus-circle me-1"></i> Create New Game Task
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Title</th>
                <th style="min-width:260px;">Description</th>
                <th>Target Area</th>
                <th class="text-center">Points</th>
                <th class="text-center">Week</th>
                <th class="text-center">Active?</th>
                <th class="text-center">Common?</th>
                <th>Media</th>
                <th>Created</th>
                <th>Created By</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="11" class="text-muted text-center py-4">
                        No game tasks found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>

                        <td class="text-muted">
                            <div class="text-truncate" style="max-width: 420px;" title="@item.Description">
                                @item.Description
                            </div>
                        </td>

                        <td>
                            @Html.DisplayFor(_ => item.TargetArea) @* uses [Display(Name=...)] on enum *@
                        </td>

                        <td class="text-center">@item.Points</td>

                        <td class="text-center">@item.SuggestedWeek</td>

                        <td class="text-center">
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>

                        <td class="text-center">
                            @if (item.IsCommonTask)
                            {
                                <span class="badge bg-primary">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark">No</span>
                            }
                        </td>

                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.MediaLink))
                            {
                                <a href="@item.MediaLink" target="_blank" rel="noopener"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-link me-1"></i> Link
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>

                        <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                        @{
    var email = item.CreatedByUser?.Email;
}
<td>
    @if (!string.IsNullOrWhiteSpace(email))
    {
        @email <small class="text-muted"> (@item.CreatedByUser!.UserType) </small>
    }
    else if (!string.IsNullOrWhiteSpace(item.CreatedByUserId))
    {
        @item.CreatedByUserId
    }
    else
    {
        <span class="text-muted">—</span>
    }
</td>


                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                                <i class="fas fa-edit me-1"></i> Edit
                            </a>

                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this task? This cannot be undone.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash-alt me-1"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
