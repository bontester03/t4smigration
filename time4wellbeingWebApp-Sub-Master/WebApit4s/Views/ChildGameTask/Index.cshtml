@model IEnumerable<WebApit4s.Models.ChildGameTask>
@{
    ViewData["Title"] = "My Game Tasks";
    var child = ViewBag.ActiveChild as WebApit4s.Models.Child;
    var history = ViewBag.PointHistory as List<WebApit4s.Models.UserPointHistory>;

    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";

    var activeTasks = Model.Where(x => !x.IsCompleted && !x.IsExpired).ToList();
    var completedOrExpiredTasks = Model.Where(x => x.IsCompleted || x.IsExpired).ToList();
}

<div class="container-fluid px-2 px-md-4">

    <!-- Child Info Card -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-child me-1"></i> Child Information
            </div>
            <a asp-controller="Dashboard" asp-action="LandingPage" class="btn btn-outline-light btn-sm">
                <i class="fa-solid fa-arrow-left me-2"></i> Back to Dashboard
            </a>
        </div>

        <div class="card-body d-flex align-items-center">
            @if (child != null)
            {
                <div>
                    <h5 class="mb-1"><i class="fas fa-user me-1 text-primary"></i> @child.ChildName</h5>
                    <p class="mb-0 text-muted">
                        <i class="fas fa-birthday-cake me-1 text-secondary"></i> Age: <strong>@child.Age</strong><br />
                        <i class="fas fa-coins me-1 text-warning"></i> Coins: <strong>@child.TotalPoints</strong>
                    </p>
                </div>
            }
        </div>
    </div>
 
    @if (ViewBag.AvailableRewards != null)
    {
        @await Html.PartialAsync("_AvailableRewardsPartial", (WebApit4s.ViewModels.AvailableRewardsViewModel)ViewBag.AvailableRewards)
    }
    <!-- Tab Navigation -->
    <ul class="nav nav-tabs flex-wrap mb-3" id="taskTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="active-tab" data-bs-toggle="tab" data-bs-target="#activeTasks" type="button" role="tab">
                <i class="fas fa-play-circle me-1"></i> Active Tasks
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completedTasks" type="button" role="tab">
                <i class="fas fa-history me-1"></i> Completed / Expired
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="points-tab" data-bs-toggle="tab" data-bs-target="#pointHistory" type="button" role="tab">
                <i class="fas fa-coins me-1"></i>Gain Coin History
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="taskTabContent">

        <!-- Active Tasks -->
        <div class="tab-pane fade show active" id="activeTasks" role="tabpanel">
            <div class="card shadow-sm mb-4">
                <div class="card-body table-responsive">
                    @if (activeTasks.Any())
                    {
                        <table class="table table-bordered table-striped table-hover">
                            <thead class="table-success text-nowrap">
                                <tr>
                                    <th>Task</th>
                                    <th>Description</th>
                                    <th>Points</th>
                                    <th>Assigned</th>
                                    <th>Status</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in activeTasks)
                                {
                                    <tr>
                                        <td>
                                            @task.GameTask.Title
                                            @if (task.GameTask.IsCommonTask)
                                            {
                                                <span class="badge bg-info ms-1">Common</span>
                                            }
                                        </td>
                                        <td class="text-truncate">@task.GameTask.Description</td>
                                        <td><strong>@task.GameTask.Points</strong></td>
                                        <td>@task.AssignedDate.ToString("dd MMM yyyy")</td>
                                        <td><span class="badge bg-warning text-dark">Pending</span></td>
                                        <td class="text-center">
                                            <form asp-action="Complete" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@task.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-check-circle me-1"></i> Complete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small">No active tasks at the moment.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Completed / Expired Tasks -->
        <div class="tab-pane fade" id="completedTasks" role="tabpanel">
            <div class="card shadow-sm">
                <div class="card-body table-responsive">
                    @if (completedOrExpiredTasks.Any())
                    {
                        <table class="table table-bordered table-striped table-hover">
                            <thead class="table-secondary text-nowrap">
                                <tr>
                                    <th>Task</th>
                                    <th>Description</th>
                                    <th>Points</th>
                                    <th>Assigned</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in completedOrExpiredTasks)
                                {
                                    <tr>
                                        <td>@task.GameTask.Title</td>
                                        <td class="text-truncate">@task.GameTask.Description</td>
                                        <td><strong>@task.GameTask.Points</strong></td>
                                        <td>@task.AssignedDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (task.IsCompleted)
                                            {
                                                <span class="badge bg-success">Completed</span>
                                            }
                                            else if (task.IsExpired)
                                            {
                                                <span class="badge bg-danger">Expired</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small">No completed or expired tasks yet.</p>
                    }
                </div>
            </div>
        </div>

        <!-- ✅ Point History -->
        <div class="tab-pane fade" id="pointHistory" role="tabpanel">
            <div class="card shadow-sm mb-4">
            
                <div class="card-body table-responsive">
                    @if (history != null && history.Any())
                    {
                        <table class="table table-bordered table-striped table-hover">
                            <thead class="table-info text-nowrap">
                                <tr>
                                    <th>Change</th>
                                    <th>Balance</th>
                                    <th>Reason</th>
                                    <th>Notes</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in history)
                                {
                                    <tr>
                                        <td class="@(h.Delta >= 0 ? "text-success fw-bold" : "text-danger fw-bold")">
                                            @((h.Delta >= 0 ? "+" : "") + h.Delta)
                                        </td>
                                        <td><strong>@h.BalanceAfter</strong></td>
                                        <td><span class="badge bg-info text-dark">@h.Reason</span></td>
                                        <td>@h.Notes</td>
                                        <td>@h.CreatedUtc.ToString("dd MMM yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small">No point history yet for this child.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
