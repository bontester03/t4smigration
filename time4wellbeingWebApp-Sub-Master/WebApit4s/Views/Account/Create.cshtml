@using WebApit4s.Identity
@model WebApit4s.ViewModels.CreateUserViewModel

@{
    ViewData["Title"] = "Create New User";
    ViewData["ActivePage"] = "CreateUser";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .create-user-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        padding: 3rem 2rem;
        color: white;
        margin-bottom: 2rem;
        box-shadow: 0 8px 32px rgba(102, 126, 234, 0.3);
    }
    .create-user-card {
        border: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 15px;
        overflow: hidden;
    }
    .form-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        padding: 2rem;
        margin-bottom: 2rem;
    }
    .feature-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }
    .stats-box {
        background: white;
        border-radius: 10px;
        padding: 1.5rem;
        text-align: center;
        border: 2px solid #e9ecef;
        transition: all 0.3s;
    }
    .stats-box:hover {
        border-color: #667eea;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.2);
    }
    .action-btn {
        transition: all 0.3s;
    }
    .action-btn:hover {
        transform: scale(1.05);
    }
</style>

<div class="container-fluid px-4 mt-4">
    <!-- Hero Section -->
    <div class="create-user-hero">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="fw-bold mb-3">
                    <i data-feather="user-plus" class="me-3"></i>Create New User
                </h1>
                <p class="lead mb-0">
                    Add a new user account to the system with specified roles and permissions
                </p>
            </div>
            <div class="col-md-4 text-md-end">
                <div style="font-size: 5rem; opacity: 0.2;">
                    <i data-feather="users"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i data-feather="alert-triangle" class="me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i data-feather="check-circle" class="me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Quick Info Boxes -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stats-box">
                <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    <i data-feather="shield"></i>
                </div>
                <h6 class="fw-bold mb-1">Admin Access</h6>
                <p class="text-muted small mb-0">Full system control</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-box">
                <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #28a745 0%, #218838 100%); color: white;">
                    <i data-feather="briefcase"></i>
                </div>
                <h6 class="fw-bold mb-1">Employee Access</h6>
                <p class="text-muted small mb-0">Staff management</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-box">
                <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #17a2b8 0%, #138496 100%); color: white;">
                    <i data-feather="user"></i>
                </div>
                <h6 class="fw-bold mb-1">Parent Access</h6>
                <p class="text-muted small mb-0">Child management</p>
            </div>
        </div>
    </div>

    <!-- Create User Form -->
    <div class="card create-user-card">
        <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 1rem 1.5rem;">
            <h5 class="mb-0">
                <i data-feather="edit" class="me-2"></i>User Details
            </h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" class="row g-4">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label fw-bold">
                        <i data-feather="user" style="width: 16px; height: 16px;"></i>
                        Full Name
                    </label>
                    <input asp-for="FullName" class="form-control form-control-lg" placeholder="Enter full name" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-bold">
                        <i data-feather="mail" style="width: 16px; height: 16px;"></i>
                        Email Address
                    </label>
                    <input asp-for="Email" class="form-control form-control-lg" placeholder="user@example.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Password" class="form-label fw-bold">
                        <i data-feather="lock" style="width: 16px; height: 16px;"></i>
                        Password
                    </label>
                    <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Enter secure password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                    <small class="text-muted d-block mt-1">
                        <i data-feather="info" style="width: 12px; height: 12px;"></i>
                        Must be at least 6 characters
                    </small>
                </div>

                <div class="col-md-6">
                    <label asp-for="SelectedUserType" class="form-label fw-bold">
                        <i data-feather="users" style="width: 16px; height: 16px;"></i>
                        User Type
                    </label>
                    <select asp-for="SelectedUserType" asp-items="Html.GetEnumSelectList<UserType>()" class="form-select form-select-lg">
                        <option value="">-- Select User Type --</option>
                    </select>
                    <span asp-validation-for="SelectedUserType" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <div class="form-section">
                        <div class="form-check">
                            <input asp-for="IsApproved" class="form-check-input" type="checkbox" style="width: 1.5rem; height: 1.5rem;" />
                            <label asp-for="IsApproved" class="form-check-label fw-bold ms-2">
                                <i data-feather="check-circle" style="width: 16px; height: 16px;"></i>
                                Is Approved by Admin
                            </label>
                            <div class="text-muted small mt-2 ms-5">
                                Check this box to immediately approve the user account
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <hr class="my-3">
                </div>

                <div class="col-12 d-flex justify-content-between">
                    <a asp-action="UserList" class="btn btn-outline-secondary btn-lg action-btn">
                        <i data-feather="arrow-left" class="me-2"></i>Back to User List
                    </a>
                    <button type="submit" class="btn btn-success btn-lg action-btn">
                        <i data-feather="user-plus" class="me-2"></i>Create User
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Information Card -->
    <div class="card create-user-card mt-4">
        <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 1rem 1.5rem;">
            <h5 class="mb-0">
                <i data-feather="info" class="me-2"></i>User Type Permissions
            </h5>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-4">
                    <h6 class="fw-bold text-primary mb-3">
                        <i data-feather="shield" class="me-2"></i>Admin
                    </h6>
                    <ul class="ps-3">
                        <li class="mb-2">Full system access</li>
                        <li class="mb-2">Manage all users</li>
                        <li class="mb-2">Configure system settings</li>
                        <li class="mb-2">View all reports</li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold text-success mb-3">
                        <i data-feather="briefcase" class="me-2"></i>Employee
                    </h6>
                    <ul class="ps-3">
                        <li class="mb-2">Manage registrations</li>
                        <li class="mb-2">View school data</li>
                        <li class="mb-2">Process approvals</li>
                        <li class="mb-2">Generate reports</li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-bold text-info mb-3">
                        <i data-feather="user" class="me-2"></i>Parent
                    </h6>
                    <ul class="ps-3">
                        <li class="mb-2">Register children</li>
                        <li class="mb-2">Update child information</li>
                        <li class="mb-2">View own records</li>
                        <li class="mb-2">Manage consent</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Initialize Feather Icons
        if (typeof feather !== 'undefined') {
            feather.replace();
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof feather !== 'undefined') {
                feather.replace();
            }
        });
    </script>
}
