@model WebApit4s.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

<style>
    .login-card {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(10px);
    }
    .login-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        padding: 2rem 1.5rem;
        text-align: center;
        color: white;
        border-radius: 20px 20px 0 0;
    }
    .login-header h3 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .login-header p {
        font-size: 0.95rem;
        opacity: 0.95;
        margin: 0;
    }
    .login-body {
        padding: 2rem 1.5rem;
    }
    .form-control-modern {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        padding-left: 2.75rem;
        font-size: 0.95rem;
        transition: all 0.3s;
    }
    .form-control-modern:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.15);
    }
    .form-label-modern {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .input-icon {
        position: relative;
    }
    .input-icon i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        z-index: 5;
    }
    .btn-modern {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        border-radius: 10px;
        padding: 0.75rem;
        font-size: 1rem;
        font-weight: 600;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
    }
    .btn-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.5);
        background: linear-gradient(135deg, #059669 0%, #047857 100%);
        color: white;
    }
    .welcome-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.2);
        padding: 0.4rem 0.9rem;
        border-radius: 50px;
        margin-bottom: 0.75rem;
        backdrop-filter: blur(10px);
        font-size: 0.85rem;
    }
    .signup-box {
        text-align: center;
        padding: 1.25rem;
        background: #f0fdf4;
        border-radius: 10px;
        margin-top: 1.25rem;
        border: 1px solid #d1fae5;
    }
    .signup-box p {
        margin: 0;
        color: #065f46;
        font-size: 0.9rem;
    }
    .signup-box a {
        color: #10b981;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
    }
    .signup-box a:hover {
        color: #059669;
        text-decoration: underline;
    }
    .forgot-link {
        text-align: right;
        margin-top: 0.5rem;
    }
    .forgot-link a {
        color: #10b981;
        font-size: 0.85rem;
        text-decoration: none;
        transition: all 0.3s;
    }
    .forgot-link a:hover {
        color: #059669;
        text-decoration: underline;
    }
    .terms-text {
        text-align: center;
        font-size: 0.8rem;
        color: #6b7280;
        margin-top: 1.25rem;
    }
    .terms-text a {
        color: #10b981;
        text-decoration: none;
    }
    .terms-text a:hover {
        text-decoration: underline;
        color: #059669;
    }
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 1.25rem 0;
    }
    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #e0e0e0;
    }
    .divider span {
        padding: 0 1rem;
        color: #9ca3af;
        font-size: 0.85rem;
    }
</style>

<div class="col-md-6 d-flex align-items-center py-5">
    <div class="container my-auto">
        <div class="row">
            <div class="col-11 col-lg-10 mx-auto">
                <div class="login-card">
                    <!-- Header -->
                    <div class="login-header">
                        <div class="welcome-badge">
                            <i class="fas fa-heart me-2"></i>Welcome Back
                        </div>
                        <h3 class="mb-1">Sign In</h3>
                        <p>Continue your wellness journey</p>
                    </div>

                    <!-- Body -->
                    <div class="login-body">
                        <form id="auth-form" asp-action="Login" method="post">
                            <!-- Validation Summary -->
                            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                            {
                                <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-3" role="alert"></div>
                            }

                            <!-- Email -->
                            <div class="mb-3">
                                <label asp-for="Email" class="form-label-modern">
                                    <i class="fas fa-envelope me-2"></i>Email Address
                                </label>
                                <div class="input-icon">
                                    @* <i class="far fa-envelope"></i> *@
                                    <input asp-for="Email" class="form-control form-control-modern" placeholder="you@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <label asp-for="Password" class="form-label-modern">
                                    <i class="fas fa-lock me-2"></i>Password
                                </label>
                                <div class="input-icon">
                                   @*  <i class="fas fa-lock"></i> *@
                                    <input asp-for="Password" type="password" class="form-control form-control-modern" placeholder="Enter your password" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                                
                                <!-- Forgot Password -->
                                <div class="forgot-link">
                                    <a asp-action="ForgotPassword" asp-controller="Account">
                                        <i class="fas fa-key me-1"></i>Forgot Password?
                                    </a>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <div class="d-grid my-4">
                                <button type="submit" class="btn btn-modern">
                                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                                </button>
                            </div>

                            <!-- Terms -->
                            <div class="terms-text">
                                <i class="fas fa-shield-alt me-1"></i>
                                By signing in, you agree to our
                                <a href="https://www.time4sportuk.com/terms" target="_blank">Terms</a> and
                                <a href="https://www.time4sportuk.com/terms" target="_blank">Privacy</a>
                            </div>
                        </form>

                        <!-- Divider -->
                        <div class="divider">
                            <span>New to Time4Wellbeing?</span>
                        </div>

                        <!-- Sign Up Box -->
                        <div class="signup-box">
                            <p>
                                Don't have an account?
                                <a href="/register/step-1">
                                    <i class="fas fa-user-plus me-1"></i>Create Account
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
