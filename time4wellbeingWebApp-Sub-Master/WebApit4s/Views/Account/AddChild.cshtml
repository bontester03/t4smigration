@model WebApit4s.ViewModels.CreateChildViewModel

@{
    ViewData["Title"] = "Add Child";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <h3 class="mb-4">Add Child for Parent</h3>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <i class="fa-solid fa-child me-2"></i> Add Child
            <a asp-action="UserList" class="btn btn-sm btn-light">
                <i class="fa-solid fa-arrow-left"></i> Back to Users
            </a>
        </div>

        <div class="card-body">
            <form asp-action="AddChild" method="post">
                <input type="hidden" asp-for="ParentId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="ChildName" class="form-label fw-semibold"></label>
                    <input asp-for="ChildName" class="form-control" />
                    <span asp-validation-for="ChildName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="DateOfBirth" class="form-label text-dark fw-600"></label>
                    <input type="date"
                           class="form-control rounded-0"
                           name="DateOfBirth"
                           value="@(Model.DateOfBirth == DateTime.MinValue ? DateTime.Today.ToString("yyyy-MM-dd") : Model.DateOfBirth.ToString("yyyy-MM-dd"))"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")"
                           required />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>




                <div class="mb-3">
                    <label asp-for="Gender" class="form-label fw-semibold"></label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">-- Select Gender --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-success me-2">
                        <i class="fa-solid fa-plus"></i> Add Child
                    </button>
                    <a asp-action="UserList" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-xmark"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
