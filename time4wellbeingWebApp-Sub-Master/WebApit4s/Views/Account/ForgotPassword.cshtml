@model WebApit4s.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

<style>
    .forgot-password-card {
        background: rgba(255, 255, 255, 0.98);
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(10px);
    }
    .forgot-password-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        padding: 2rem 1.5rem;
        text-align: center;
        color: white;
        border-radius: 20px 20px 0 0;
    }
    .forgot-password-header h3 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .forgot-password-header p {
        font-size: 0.95rem;
        opacity: 0.95;
        margin: 0;
    }
    .forgot-password-body {
        padding: 2rem 1.5rem;
    }
    .form-control-modern {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        padding-left: 2.75rem;
        font-size: 0.95rem;
        transition: all 0.3s;
        position: relative;
        background-color: white;
    }
    .form-control-modern:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.15);
    }
    .form-label-modern {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .input-icon {
        position: relative;
    }
    .input-icon i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        z-index: 10;
        pointer-events: none;
    }
    .btn-modern {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        border-radius: 10px;
        padding: 0.75rem;
        font-size: 1rem;
        font-weight: 600;
        color: white;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
    }
    .btn-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.5);
        background: linear-gradient(135deg, #059669 0%, #047857 100%);
        color: white;
    }
    .icon-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.2);
        padding: 0.4rem 0.9rem;
        border-radius: 50px;
        margin-bottom: 0.75rem;
        backdrop-filter: blur(10px);
        font-size: 0.85rem;
    }
    .info-box {
        background: #f0fdf4;
        border-left: 4px solid #10b981;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        border-right: 1px solid #d1fae5;
        border-top: 1px solid #d1fae5;
        border-bottom: 1px solid #d1fae5;
    }
    .info-box p {
        margin: 0;
        color: #065f46;
        font-size: 0.9rem;
        line-height: 1.6;
    }
    .info-box i {
        color: #10b981;
    }
    .back-box {
        text-align: center;
        padding: 1.25rem;
        background: #f9fafb;
        border-radius: 10px;
        margin-top: 1.25rem;
        border: 1px solid #e5e7eb;
    }
    .back-box p {
        margin: 0;
        color: #4b5563;
        font-size: 0.9rem;
    }
    .back-box a {
        color: #10b981;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
    }
    .back-box a:hover {
        color: #059669;
        text-decoration: underline;
    }
    .steps-container {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
    }
    .step-item {
        display: flex;
        align-items: start;
        gap: 1rem;
        padding: 0.75rem 0;
    }
    .step-number {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3);
    }
    .step-content {
        flex: 1;
    }
    .step-content h6 {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 0.25rem;
    }
    .step-content p {
        font-size: 0.85rem;
        color: #6b7280;
        margin: 0;
        line-height: 1.5;
    }
    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 1.25rem 0;
    }
    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #e0e0e0;
    }
    .divider span {
        padding: 0 1rem;
        color: #9ca3af;
        font-size: 0.85rem;
        font-weight: 500;
    }
</style>

<div class="col-md-6 d-flex align-items-center py-5">
    <div class="container my-auto">
        <div class="row">
            <div class="col-11 col-lg-10 mx-auto">
                <div class="forgot-password-card">
                    <!-- Header -->
                    <div class="forgot-password-header">
                        <div class="icon-badge">
                            <i class="fas fa-key me-2"></i>Password Recovery
                        </div>
                        <h3 class="mb-1">Forgot Password?</h3>
                        <p>No worries, we'll send you reset instructions</p>
                    </div>

                    <!-- Body -->
                    <div class="forgot-password-body">
                        <!-- Alert Messages -->
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                @TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                                <i class="fas fa-check-circle me-2"></i>
                                @TempData["Success"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <!-- Info Box -->
                        <div class="info-box">
                            <p>
                                <i class="fas fa-info-circle me-2"></i>
                                Enter your registered email address and we'll send you a link to reset your password.
                            </p>
                        </div>

                        <form asp-action="ForgotPassword" method="post">
                            <!-- Validation Summary -->
                            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                            {
                                <div asp-validation-summary="All" class="alert alert-danger rounded-3 mb-3" role="alert"></div>
                            }

                            <!-- Email -->
                            <div class="mb-4">
                                <label asp-for="Email" class="form-label-modern">
                                    <i class="fas fa-envelope me-2"></i>Email Address
                                </label>
                                <div class="input-icon">
                                   @*  <i class="far fa-envelope"></i> *@
                                    <input asp-for="Email" 
                                           class="form-control form-control-modern" 
                                           placeholder="you@example.com" 
                                           autofocus />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                            </div>

                            <!-- Submit Button -->
                            <div class="d-grid mb-4">
                                <button class="btn btn-modern" type="submit">
                                    <i class="fas fa-paper-plane me-2"></i>Send Reset Link
                                </button>
                            </div>
                        </form>

                        <!-- How It Works Section -->
                        <div class="steps-container">
                            <div class="divider">
                                <span><i class="fas fa-question-circle me-2"></i>How it works</span>
                            </div>

                            <div class="step-item">
                                <div class="step-number">1</div>
                                <div class="step-content">
                                    <h6>Enter Your Email</h6>
                                    <p>Provide the email address you used to register your account</p>
                                </div>
                            </div>

                            <div class="step-item">
                                <div class="step-number">2</div>
                                <div class="step-content">
                                    <h6>Check Your Inbox</h6>
                                    <p>We'll send you a secure password reset link via email</p>
                                </div>
                            </div>

                            <div class="step-item">
                                <div class="step-number">3</div>
                                <div class="step-content">
                                    <h6>Create New Password</h6>
                                    <p>Click the link and set up a new secure password for your account</p>
                                </div>
                            </div>
                        </div>

                        <!-- Divider -->
                        <div class="divider mt-4">
                            <span>Remember your password?</span>
                        </div>

                        <!-- Back to Login Box -->
                        <div class="back-box">
                            <p>
                                <a asp-action="Login" asp-controller="Account">
                                    <i class="fas fa-arrow-left me-2"></i>Back to Sign In
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
