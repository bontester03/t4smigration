@model WebApit4s.ViewModels.AvatarPickerViewModel
@{
    ViewData["Title"] = "Choose Avatar";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="container-xl mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0"><i class="fa-regular fa-face-smile me-2"></i> Choose an Avatar</h1>
        <a class="btn btn-outline-secondary btn-sm"
           asp-controller="Dashboard"
           asp-action="Index">
            <i class="fa-solid fa-arrow-left me-1"></i> Back
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger"><i class="fa-solid fa-circle-exclamation me-1"></i>@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="fa-solid fa-circle-check me-1"></i>@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="SelectAvatar" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ChildId" />
                <input type="hidden" asp-for="ReturnAction" value="Index" />
                <input type="hidden" asp-for="ReturnController" value="Dashboard" />


                <div class="row g-3">
                    @if (Model.Avatars?.Any() ?? false)
                    {
                        foreach (var url in Model.Avatars)
                        {
                            var isCurrent = string.Equals(url, Model.CurrentAvatarUrl, StringComparison.OrdinalIgnoreCase);
                            <div class="col-6 col-sm-4 col-md-3 col-lg-2 text-center">
                                <label class="d-block avatar-tile">
                                    <input type="radio" name="SelectedAvatarUrl" value="@url" class="d-none" @(isCurrent ? "checked" : "") />
                                    <img src="@Url.Content(url)" class="img-fluid rounded-circle border p-2 avatar-img" alt="Avatar" />
                                </label>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert alert-warning mb-0">
                                No avatars found in <code>wwwroot/characters</code>.
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-floppy-disk me-1"></i> Save Avatar
                    </button>
                    <a class="btn btn-outline-secondary"
                       asp-controller="Dashboard"
                       asp-action="Index">
                        Cancel
                    </a>

                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .avatar-img {
        width: 100%;
        aspect-ratio: 1/1;
        object-fit: contain;
        transition: border-color .15s, box-shadow .15s;
    }

    .avatar-tile:hover .avatar-img {
        border-color: #0d6efd;
    }

    .avatar-tile input:checked + .avatar-img {
        border-color: #198754;
        box-shadow: 0 0 0 .25rem rgba(0,0,0,.25);
    }
</style>
