@model List<WebApit4s.Models.Child>
@using System.Linq
@{
    ViewData["Title"] = "Parent Dashboard";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="card shadow mb-4">

    <!-- Header -->
    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
        <div>
            <i class="fas fa-users me-2"></i> Your Children
        </div>
        <a asp-controller="Dashboard" asp-action="LandingPage" class="btn btn-outline-light btn-sm">
            <i class="fa-solid fa-arrow-left me-2"></i> Back to Dashboard
        </a>
    </div>

    <!-- Body -->
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-warning shadow-sm">
                <i class="fas fa-exclamation-circle me-2"></i> You haven't added any children yet.
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var child in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 border-start border-4 border-success shadow-sm">
                            <div class="card-body d-flex flex-column">
                                <!-- Child Info -->
                                <h5 class="card-title text-primary mb-1">
                                    <i class="fas fa-child me-2"></i> @child.ChildName
                                </h5>
                                <p class="text-muted small mb-3">
                                    <i class="fas fa-birthday-cake me-1 text-secondary"></i>
                                    Age: <strong>@child.Age</strong><br />
                                    <i class="fas fa-coins me-1 text-warning"></i>
                                    Coins: <strong>@child.TotalPoints</strong>
                                </p>

                                <!-- Actions -->
                                <div class="mt-auto">
                                    <!-- Rewards Section -->
                                    <div class="mb-2">
                                        <span class="fw-bold text-success small">
                                            <i class="fas fa-gift me-1"></i> Rewards
                                        </span>
                                        <div class="d-grid gap-2 mt-1">
                                            @* <a asp-action="CreateReward" asp-controller="Parent" class="btn btn-outline-success btn-sm" title="Create a reward available for all children">
                                                <i class="fas fa-gift me-1"></i> Create Common Reward
                                            </a> *@
                                            <a asp-action="CreateReward"
                                               asp-controller="Parent"
                                               asp-route-childId="@child.Id"
                                               class="btn btn-outline-success btn-sm"
                                               title="Create a reward only for this child">
                                                <i class="fas fa-gift me-1"></i> Create Reward
                                            </a>
                                            <a asp-action="MyRewards"
                                               asp-controller="Parent"
                                               class="btn btn-outline-primary btn-sm"
                                               title="View all rewards you have created">
                                                <i class="fas fa-list-alt me-1"></i> My Rewards
                                            </a>
                                            <a asp-action="ApproveRedemptions"
                                               asp-controller="Parent"
                                               asp-route-childId="@child.Id"
                                               class="btn btn-outline-primary btn-sm"
                                               title="Approve or reject reward redemption requests">
                                                <i class="fas fa-check-circle me-1"></i> Approve Requests
                                            </a>
                                        </div>
                                    </div>

                                    <!-- Tasks Section -->
                                    <div>
                                        <span class="fw-bold text-warning small">
                                            <i class="fas fa-tasks me-1"></i> Tasks
                                        </span>
                                        <div class="d-grid gap-2 mt-1">
                                            <!-- Create a new custom task (Parent/AddTask GET) -->
                                            <a asp-action="AddTask"
                                               asp-controller="Parent"
                                               class="btn btn-outline-secondary btn-sm"
                                               title="Create a new custom task">
                                                <i class="fas fa-plus me-1"></i> Add Task
                                            </a>

                                            <!-- View own tasks -->
                                            <a asp-action="MyTasks"
                                               asp-controller="Parent"
                                               class="btn btn-outline-primary btn-sm"
                                               title="View tasks you have created">
                                                <i class="fas fa-list me-1"></i> My Tasks
                                            </a>

                                            <!-- Assign an existing task to this child -->
                                            <a asp-action="AssignTask"
                                               asp-controller="Parent"
                                               asp-route-childId="@child.Id"
                                               class="btn btn-outline-warning btn-sm"
                                               title="Assign a task for this child">
                                                <i class="fas fa-tasks me-1"></i> Assign Task
                                            </a>

                                            <!-- Delete Child (opens modal) -->
                                            <button type="button"
                                                    class="btn btn-sm btn-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteChildModal"
                                                    data-id="@child.Id"
                                                    data-name="@child.ChildName">
                                                <i class="fas fa-user-times me-1"></i> Delete Child
                                            </button>
                                        </div>
                                    </div>
                                </div> <!-- /mt-auto -->
                            </div> <!-- /card-body -->
                        </div> <!-- /card -->
                    </div> <!-- /col -->
                }
            </div> <!-- /row -->
        }
    </div> <!-- /card-body -->
</div> <!-- /card -->

<!-- Reusable modal (place once per page) -->
<div class="modal fade" id="deleteChildModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">
          <i class="fas fa-exclamation-triangle me-2"></i> Confirm delete
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Delete <strong id="delChildName"></strong>? This cannot be undone.
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <form id="deleteChildForm" method="post" asp-action="DeleteChild" asp-controller="Parent" class="d-inline">
          <input type="hidden" name="id" id="delChildId" />
          @Html.AntiForgeryToken()
          <button type="submit" class="btn btn-danger">
            <i class="fas fa-trash-alt me-1"></i> Delete
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        (() => {
            const modal = document.getElementById('deleteChildModal');
            if (!modal) return;
            modal.addEventListener('show.bs.modal', e => {
                const btn = e.relatedTarget;
                if (!btn) return;
                const id = btn.getAttribute('data-id');
                const name = btn.getAttribute('data-name') || '';
                const idInput = document.getElementById('delChildId');
                const nameEl = document.getElementById('delChildName');
                if (idInput) idInput.value = id;
                if (nameEl) nameEl.textContent = name;
            });
        })();
    </script>
}
