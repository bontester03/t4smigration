@model WebApit4s.ViewModels.CreateGameTaskViewModel
@{
    ViewData["Title"] = "Create Task";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="container-fluid px-2 px-md-4">
    <div class="row">
        <div class="col-lg-10 mx-auto">

            <!-- Top actions -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <a asp-action="Dashboard" asp-controller="Parent" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
                </a>
                <a asp-action="MyTasks" asp-controller="Parent" class="btn btn-success">
                    <i class="fas fa-list me-1"></i> My Tasks
                </a>
            </div>

            <!-- Flash messages -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-1"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-times-circle me-1"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Card -->
            <div class="card shadow mb-4">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-plus-circle me-1"></i> Create Task
                </div>
                <div class="card-body">
                    <form asp-action="AddTask" asp-controller="Parent" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <partial name="~/Views/Shared/_GameTaskForm.cshtml" model="Model" />

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save me-1"></i> Create Task
                            </button>
                            <a asp-action="Dashboard" asp-controller="Parent" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
